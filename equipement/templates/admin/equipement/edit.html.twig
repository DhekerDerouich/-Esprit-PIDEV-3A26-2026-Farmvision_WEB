{# templates/admin/equipement/edit.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block body %}
<div style="margin-bottom: 2rem;">
    <a href="{{ path('admin_equipement_index') }}" class="btn" style="background: var(--bg-panel);">← Retour</a>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h1 style="font-size: 1.5rem; margin-bottom: 1.5rem;">Modifier l'équipement</h1>
    
    <form method="post">
        <div class="form-group" style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Nom</label>
            <input type="text" name="nom" value="{{ equipement.nom }}" class="form-control" required style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border); background: var(--bg);">
        </div>
        
        <div class="form-group" style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Type</label>
            <select name="type" class="form-control" required style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border); background: var(--bg);">
                <option value="Tracteur" {% if equipement.type == 'Tracteur' %}selected{% endif %}>Tracteur</option>
                <option value="Moissonneuse" {% if equipement.type == 'Moissonneuse' %}selected{% endif %}>Moissonneuse</option>
                <option value="Pulvérisateur" {% if equipement.type == 'Pulvérisateur' %}selected{% endif %}>Pulvérisateur</option>
                <option value="Charrue" {% if equipement.type == 'Charrue' %}selected{% endif %}>Charrue</option>
                <option value="Semoir" {% if equipement.type == 'Semoir' %}selected{% endif %}>Semoir</option>
                <option value="Autre" {% if equipement.type == 'Autre' %}selected{% endif %}>Autre</option>
            </select>
        </div>
        
        <div class="form-group" style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">État</label>
            <select name="etat" class="form-control" required style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border); background: var(--bg);">
                <option value="Fonctionnel" {% if equipement.etat == 'Fonctionnel' %}selected{% endif %}>Fonctionnel</option>
                <option value="En panne" {% if equipement.etat == 'En panne' %}selected{% endif %}>En panne</option>
                <option value="Maintenance" {% if equipement.etat == 'Maintenance' %}selected{% endif %}>Maintenance</option>
            </select>
        </div>
        
        <div class="form-group" style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Date d'achat</label>
            <input type="date" name="date_achat" value="{{ equipement.dateAchat ? equipement.dateAchat|date('Y-m-d') : '' }}" class="form-control" style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border); background: var(--bg);">
        </div>
        
        <div class="form-group" style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Durée de vie estimée (années)</label>
            <input type="number" name="duree_vie_estimee" value="{{ equipement.dureeVieEstimee }}" class="form-control" style="width: 100%; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--border); background: var(--bg);">
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
            <a href="{{ path('admin_equipement_index') }}" class="btn" style="background: var(--bg-panel);">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}