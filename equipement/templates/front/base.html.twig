{# templates/front/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmVision - Agriculture Intelligente</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --green-deep: #1a3a2a;
            --green-mid: #2d6a4f;
            --green-light: #52b788;
            --green-pale: #b7e4c7;
            --green-mist: #d8f3dc;
            --cream: #faf7f2;
            --text: #1a1a18;
            --text-muted: #5a6b5e;
            --gold: #c8a84b;
            --gold-dim: rgba(200, 168, 75, 0.15);
            --red: #e05c5c;
            --red-dim: rgba(224, 92, 92, 0.12);
            --border: rgba(45, 106, 79, 0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--text);
        }

        nav {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(250, 247, 242, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 72px;
            z-index: 100;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--green-deep);
        }

        .logo span {
            color: var(--green-light);
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 500;
            transition: color 0.2s;
        }

        .nav-links a.active,
        .nav-links a:hover {
            color: var(--green-mid);
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .btn-login {
            padding: 0.5rem 1.25rem;
            background: transparent;
            border: 1px solid var(--green-mid);
            border-radius: 8px;
            color: var(--green-mid);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-login:hover {
            background: var(--green-mist);
            border-color: var(--green-light);
        }

        .btn-signup {
            padding: 0.5rem 1.25rem;
            background: var(--green-mid);
            border: none;
            border-radius: 8px;
            color: white;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.2s;
        }

        .btn-signup:hover {
            background: var(--green-deep);
            transform: translateY(-1px);
        }

        .btn-logout {
            padding: 0.5rem 1.25rem;
            background: transparent;
            border: 1px solid var(--red);
            border-radius: 8px;
            color: var(--red);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-logout:hover {
            background: var(--red-dim);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.5rem 1rem;
            background: var(--green-mist);
            border-radius: 8px;
        }

        .user-name {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--green-deep);
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            background: var(--green-mid);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
        }

        main {
            padding-top: 72px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        .btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
        }

        .btn-outline {
            border: 1px solid var(--green-mid);
            color: var(--green-mid);
            background: transparent;
        }

        .btn-outline:hover {
            background: var(--green-mist);
        }

        .btn-primary {
            background: var(--green-mid);
            color: white;
            border: none;
        }

        .btn-primary:hover {
            background: var(--green-deep);
            transform: translateY(-1px);
        }

        .card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            border: 1px solid var(--border);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
        }

        .badge {
            padding: 0.25rem 0.75rem;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .badge-success {
            background: var(--green-mist);
            color: var(--green-mid);
        }

        .badge-warning {
            background: var(--gold-dim);
            color: var(--gold);
        }

        .badge-danger {
            background: var(--red-dim);
            color: var(--red);
        }

        footer {
            background: var(--green-deep);
            color: rgba(255, 255, 255, 0.6);
            padding: 3rem;
            text-align: center;
            margin-top: 4rem;
        }

        @media (max-width: 768px) {
            nav {
                padding: 0 1rem;
            }

            .nav-links {
                display: none;
            }

            .container {
                padding: 0 1rem;
            }
        }

        /* Flash messages */
        .flash-message {
            position: fixed;
            top: 80px;
            right: 20px;
            padding: 12px 20px;
            border-radius: 8px;
            color: white;
            z-index: 1000;
            animation: slideIn 0.3s ease, fadeOut 0.5s ease 4.5s forwards;
        }

        .flash-success {
            background: var(--green-mid);
            border-left: 4px solid var(--green-light);
        }

        /* Animation fade-in au scroll */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.6s ease;
        }

        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .flash-error {
            background: var(--red-dim);
            border-left: 4px solid var(--red);
            color: var(--red);
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @keyframes fadeOut {
            to {
                opacity: 0;
                visibility: hidden;
            }
        }
    </style>
</head>

<body>
    <nav>
        <div class="logo">Farm<span>Vision</span></div>
        <ul class="nav-links">
            <li><a href="{{ path('front_home') }}"
                    class="{{ app.request.get('_route') == 'front_home' ? 'active' : '' }}">Accueil</a></li>
            <li><a href="{{ path('front_about') }}"
                    class="{{ app.request.get('_route') == 'front_about' ? 'active' : '' }}">À propos</a></li>
            {% if is_granted('ROLE_USER') %}
            <li><a href="{{ path('front_equipement_index') }}"
                    class="{{ app.request.get('_route') starts with 'front_equipement' ? 'active' : '' }}">Équipements</a>
            </li>
            <li><a href="{{ path('front_maintenance_index') }}"
                    class="{{ app.request.get('_route') starts with 'front_maintenance' ? 'active' : '' }}">Maintenances</a>
            </li>
            {% endif %}
        </ul>

        <div class="nav-actions">
            {% if app.user %}
            {# Utilisateur connecté #}
            <div class="user-info">
                <span class="user-name">{{ app.user.prenom }} {{ app.user.nom }}</span>
                <div class="user-avatar">{{ app.user.prenom|first }}{{ app.user.nom|first }}</div>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_dashboard') }}" class="btn-login">📊 Dashboard</a>
            {% elseif is_granted('ROLE_RESPONSABLE') %}
            <a href="{{ path('responsable_dashboard') }}" class="btn-login">📊 Dashboard</a>
            {% else %}
            <a href="{{ path('agriculteur_dashboard') }}" class="btn-login">👨‍🌾 Mon espace</a>
            {% endif %}
            <a href="{{ path('app_logout') }}" class="btn-logout">🚪 Déconnexion</a>
            {% else %}
            {# Utilisateur non connecté #}
            <a href="{{ path('app_login') }}" class="btn-login">🔑 Connexion</a>
            <a href="{{ path('app_register') }}" class="btn-signup">✨ Inscription</a>
            {% endif %}
        </div>
    </nav>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer>
        <p>© 2025 FarmVision. Agriculture intelligente au service des agriculteurs.</p>
    </footer>

    <!-- Flash messages -->
    {% for message in app.flashes('success') %}
    <div class="flash-message flash-success">✅ {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div class="flash-message flash-error">❌ {{ message }}</div>
    {% endfor %}

    <script>
        setTimeout(() => {
            document.querySelectorAll('.flash-message').forEach(msg => msg.remove());
        }, 5000);
    </script>
</body>

</html>