<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmVision - Agriculture Intelligente</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --green-deep: #1a3a2a;
            --green-mid: #2d6a4f;
            --green-light: #52b788;
            --green-pale: #b7e4c7;
            --green-mist: #d8f3dc;
            --cream: #faf7f2;
            --text: #1a1a18;
            --text-muted: #5a6b5e;
            --gold: #c8a84b;
            --gold-dim: rgba(200,168,75,0.15);
            --red: #e05c5c;
            --red-dim: rgba(224,92,92,0.12);
            --border: rgba(45, 106, 79, 0.15);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--text);
        }

        nav {
            position: fixed; top: 0; width: 100%;
            background: rgba(250, 247, 242, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 72px;
            z-index: 100;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--green-deep);
        }

        .logo span { color: var(--green-light); }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 500;
            transition: color 0.2s;
        }

        .nav-links a.active, .nav-links a:hover {
            color: var(--green-mid);
        }

        .btn-primary {
            padding: 0.5rem 1.5rem;
            background: var(--green-mid);
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
        }

        .btn-primary:hover {
            background: var(--green-deep);
            transform: translateY(-1px);
        }

        main {
            padding-top: 72px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        .btn {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s;
        }

        .btn-outline {
            border: 1px solid var(--green-mid);
            color: var(--green-mid);
            background: transparent;
        }

        .btn-outline:hover {
            background: var(--green-mist);
        }

        .card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            border: 1px solid var(--border);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.1);
        }

        .badge {
            padding: 0.25rem 0.75rem;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .badge-success { background: var(--green-mist); color: var(--green-mid); }
        .badge-warning { background: var(--gold-dim); color: var(--gold); }
        .badge-danger { background: var(--red-dim); color: var(--red); }

        footer {
            background: var(--green-deep);
            color: rgba(255,255,255,0.6);
            padding: 3rem;
            text-align: center;
            margin-top: 4rem;
        }

        @media (max-width: 768px) {
            nav { padding: 0 1rem; }
            .nav-links { display: none; }
            .container { padding: 0 1rem; }
        }
    </style>
</head>
<body>
    <nav>
        <div class="logo">Farm<span>Vision</span></div>
        <ul class="nav-links">
            <li><a href="{{ path('front_home') }}" class="{{ app.request.get('_route') == 'front_home' ? 'active' : '' }}">Accueil</a></li>
            <li><a href="{{ path('front_equipement_index') }}" class="{{ app.request.get('_route') starts with 'front_equipement' ? 'active' : '' }}">Équipements</a></li>
            <li><a href="{{ path('front_maintenance_index') }}" class="{{ app.request.get('_route') starts with 'front_maintenance' ? 'active' : '' }}">Maintenances</a></li>
        </ul>
        <div>
            <a href="{{ path('admin_dashboard') }}" class="btn-primary" style="text-decoration: none;">Administration</a>
        </div>
    </nav>

    <main>
        {% block body %}{% endblock %}
    </main>

    <footer>
        <p>© 2025 FarmVision. Agriculture intelligente au service des agriculteurs.</p>
    </footer>
</body>
</html>