{# templates/front/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmVision - Agriculture Intelligente</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --green-deep: #1a3a2a;
            --green-mid: #2d6a4f;
            --green-light: #40916c;
            --green-mist: #eaf5ee;
            --cream: #faf7f2;
            --text: #1a1a18;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--text);
        }

        /* ───── NAVBAR ───── */
        nav.main-nav {
            position: fixed;
            top: 0;
            width: 100%;
            height: 70px;
            padding: 0 1.5rem;

            display: flex;
            justify-content: space-between;
            align-items: center;

            background: rgba(255,255,255,0.96);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
            z-index: 200;
        }

        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--green-deep);
            text-decoration: none;
        }
        .logo span { color: var(--green-light); }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            list-style: none;
        }

        .nav-links a {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 0.45rem 0.75rem;
            font-size: 0.83rem;
            border-radius: 8px;
            text-decoration: none;
            color: #4a5f52;
            transition: all 0.2s ease;
        }

        .nav-links a:hover,
        .nav-links a.active {
            background: var(--green-mist);
            color: var(--green-mid);
            transform: translateY(-1px);
        }

        /* Dropdown */
        .has-dropdown { position: relative; }

        .nav-dropdown {
            position: absolute;
            top: 110%;
            left: 0;
            background: white;
            border-radius: 10px;
            padding: 0.4rem 0;
            min-width: 170px;
            border: 1px solid rgba(0,0,0,0.06);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            display: none;
        }

        .has-dropdown:hover .nav-dropdown {
            display: block;
        }

        .nav-dropdown a {
            padding: 0.55rem 1rem;
        }

        .nav-dropdown a:hover {
            background: #f1f7f3;
        }

        /* Actions */
        .nav-actions {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .nav-divider {
            width: 1px;
            height: 22px;
            background: linear-gradient(to bottom, transparent, #ccc, transparent);
            opacity: 0.6;
        }

        /* User */
        .user-pill {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0.35rem 0.9rem 0.35rem 0.4rem;
            background: linear-gradient(135deg, #eaf5ee, #d8f3dc);
            border: 1px solid rgba(45,106,79,0.25);
            border-radius: 999px;
            transition: 0.25s;
        }

        .user-pill:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(0,0,0,0.08);
        }

        .user-avatar {
            width: 30px;
            height: 30px;
            background: linear-gradient(135deg, #2d6a4f, #40916c);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 11px;
            font-weight: 700;
        }

        .user-name {
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--green-deep);
        }

        .user-role {
            font-size: 0.65rem;
            color: #6c8f7a;
        }

        /* Buttons */
        .btn-dash {
            padding: 0.4rem 0.9rem;
            border-radius: 8px;
            background: var(--green-mid);
            color: white;
            font-size: 0.8rem;
            font-weight: 600;
            text-decoration: none;
        }

        .btn-dash:hover {
            background: var(--green-deep);
        }

        .btn-logout {
            padding: 0.4rem 0.9rem;
            border-radius: 8px;
            border: 1px solid rgba(192,60,60,0.3);
            color: #c03c3c;
            text-decoration: none;
        }

        .btn-logout:hover {
            background: rgba(192,60,60,0.08);
        }

        main {
            padding-top: 80px;
        }

        footer {
            margin-top: 50px;
            padding: 2rem;
            text-align: center;
            background: var(--green-deep);
            color: rgba(255,255,255,0.6);
        }
    </style>
</head>

<body>

<nav class="main-nav">

    <a href="{{ path('front_home') }}" class="logo">Farm<span>Vision</span></a>

    <ul class="nav-links">
        <li><a href="{{ path('front_home') }}">Accueil</a></li>
        <li><a href="{{ path('front_about') }}">À propos</a></li>

        {% if is_granted('ROLE_USER') %}

        <li class="has-dropdown">
            <a href="#">📂 Gestion</a>
            <div class="nav-dropdown">
                <a href="{{ path('front_equipement_index') }}">⚙️ Équipements</a>
                <a href="{{ path('front_maintenance_index') }}">🔧 Maintenances</a>
                <a href="{{ path('front_stock_index') }}">📦 Stocks</a>
            </div>
        </li>

        <li class="has-dropdown">
            <a href="#">🌱 Cultures</a>
            <div class="nav-dropdown">
                <a href="{{ path('front_culture_index') }}">🌿 Cultures</a>
                <a href="{{ path('front_parcelle_index') }}">🗺️ Parcelles</a>
            </div>
        </li>

        <li><a href="{{ path('front_marketplace_index') }}">🛒 Market</a></li>

        <li class="has-dropdown">
            <a href="#">💰 Finances</a>
            <div class="nav-dropdown">
                <a href="{{ path('front_finance_dashboard') }}">📊 Dashboard</a>
                <a href="{{ path('front_finance_depenses') }}">💸 Dépenses</a>
                <a href="{{ path('front_finance_revenus') }}">💵 Revenus</a>
            </div>
        </li>

        {% endif %}
    </ul>

    <div class="nav-actions">
        {% if app.user %}
            <div class="user-pill">
                <div class="user-avatar">
                    {{ app.user.prenom|first }}{{ app.user.nom|first }}
                </div>
                <div>
                    <div class="user-name">{{ app.user.prenom }}</div>
                    <div class="user-role">Utilisateur</div>
                </div>
            </div>

            <div class="nav-divider"></div>

            <a href="{{ path('agriculteur_dashboard') }}" class="btn-dash">📊 Dashboard</a>
            <a href="{{ path('app_logout') }}" class="btn-logout">🚪 Déconnexion</a>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn-dash">🔑 Connexion</a>
        {% endif %}
    </div>

</nav>

<main>
    {% block body %}{% endblock %}
</main>

<footer>
    © 2025 FarmVision — Agriculture intelligente
</footer>

</body>
</html>