{# templates/front/base.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmVision - Agriculture Intelligente</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --green-deep: #1a3a2a;
            --green-mid: #2d6a4f;
            --green-light: #52b788;
            --green-pale: #b7e4c7;
            --green-mist: #d8f3dc;
            --cream: #faf7f2;
            --text: #1a1a18;
            --text-muted: #5a6b5e;
            --gold: #c8a84b;
            --gold-dim: rgba(200, 168, 75, 0.15);
            --red: #e05c5c;
            --red-dim: rgba(224, 92, 92, 0.12);
            --border: rgba(45, 106, 79, 0.15);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }

        /* ── Main navbar ── */
        nav.main-nav {
            position: fixed; top: 0; width: 100%;
            background: rgba(250, 247, 242, 0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0 4rem;
            display: flex; justify-content: space-between; align-items: center;
            height: 72px; z-index: 200;
        }
        .logo { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; color: var(--green-deep); }
        .logo span { color: var(--green-light); }
        .nav-links { display: flex; gap: 2rem; list-style: none; align-items: center; }
        .nav-links a { text-decoration: none; color: var(--text-muted); font-weight: 500; transition: color 0.2s; }
        .nav-links a.active, .nav-links a:hover { color: var(--green-mid); }
        .nav-actions { display: flex; align-items: center; gap: 1rem; }

        /* ── Dropdown ── */
        .nav-links li.has-dropdown { position: relative; }
        .nav-links li.has-dropdown > a::after { content: ' ▾'; font-size: 0.7rem; }
        .nav-dropdown {
            display: none; position: absolute; top: calc(100% + 12px); left: 0;
            background: #ffffff; border: 1px solid var(--border);
            border-radius: 10px; box-shadow: 0 8px 30px rgba(0,0,0,0.1);
            min-width: 180px; z-index: 300; overflow: hidden;
        }
        .nav-dropdown a { display: block; padding: 0.65rem 1.25rem; color: var(--text-muted); text-decoration: none; font-size: 0.9rem; transition: background 0.15s; }
        .nav-dropdown a:hover { background: var(--green-mist); color: var(--green-mid); }
        .nav-links li.has-dropdown:hover .nav-dropdown { display: block; }

        /* ── Sub-navbar ── */
        nav.sub-nav {
            position: fixed; top: 72px; width: 100%;
            background: var(--green-deep);
            z-index: 199; display: flex; justify-content: center;
            height: 44px; align-items: center;
        }
        nav.sub-nav a {
            color: rgba(255,255,255,0.7); text-decoration: none;
            padding: 0 1.5rem; height: 100%; display: flex; align-items: center;
            font-size: 0.9rem; font-weight: 500;
            border-right: 1px solid rgba(255,255,255,0.1); transition: all 0.2s;
        }
        nav.sub-nav a:first-child { border-left: 1px solid rgba(255,255,255,0.1); }
        nav.sub-nav a:hover, nav.sub-nav a.active { background: rgba(255,255,255,0.12); color: #fff; }

        /* ── Main content ── */
        main { padding-top: 72px; }
        main.with-subnav { padding-top: 116px; }

        /* ── Buttons ── */
        .btn { padding: 0.5rem 1rem; border-radius: 8px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.2s; cursor: pointer; }
        .btn-outline { border: 1px solid var(--green-mid); color: var(--green-mid); background: transparent; }
        .btn-outline:hover { background: var(--green-mist); }
        .btn-primary { background: var(--green-mid); color: white; border: none; }
        .btn-primary:hover { background: var(--green-deep); transform: translateY(-1px); }
        .btn-login { padding: 0.5rem 1.25rem; background: transparent; border: 1px solid var(--green-mid); border-radius: 8px; color: var(--green-mid); text-decoration: none; font-weight: 500; transition: all 0.2s; }
        .btn-login:hover { background: var(--green-mist); }
        .btn-signup { padding: 0.5rem 1.25rem; background: var(--green-mid); border: none; border-radius: 8px; color: white; text-decoration: none; font-weight: 600; transition: all 0.2s; }
        .btn-signup:hover { background: var(--green-deep); }
        .btn-logout { padding: 0.5rem 1.25rem; background: transparent; border: 1px solid var(--red); border-radius: 8px; color: var(--red); text-decoration: none; font-weight: 500; transition: all 0.2s; }
        .btn-logout:hover { background: var(--red-dim); }

        /* ── User info ── */
        .user-info { display: flex; align-items: center; gap: 10px; padding: 0.5rem 1rem; background: var(--green-mist); border-radius: 8px; }
        .user-name { font-size: 0.85rem; font-weight: 600; color: var(--green-deep); }
        .user-avatar { width: 32px; height: 32px; background: var(--green-mid); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 600; }

        /* ── Layout ── */
        .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

        /* ── Card ── */
        .card { background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.05); border: 1px solid var(--border); transition: transform 0.2s, box-shadow 0.2s; }
        .card:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,0,0,0.1); }

        /* ── Badges ── */
        .badge { padding: 0.25rem 0.75rem; border-radius: 100px; font-size: 0.7rem; font-weight: 600; }
        .badge-success { background: var(--green-mist); color: var(--green-mid); }
        .badge-warning { background: var(--gold-dim); color: var(--gold); }
        .badge-danger { background: var(--red-dim); color: var(--red); }

        /* ── Footer ── */
        footer { background: var(--green-deep); color: rgba(255,255,255,0.6); padding: 3rem; text-align: center; margin-top: 4rem; }

        /* ── Flash messages ── */
        .flash-message { position: fixed; top: 80px; right: 20px; padding: 12px 20px; border-radius: 8px; color: white; z-index: 1000; animation: slideIn 0.3s ease, fadeOut 0.5s ease 4.5s forwards; }
        .flash-success { background: var(--green-mid); border-left: 4px solid var(--green-light); }
        .flash-error { background: var(--red-dim); border-left: 4px solid var(--red); color: var(--red); }

        .fade-in { opacity: 0; transform: translateY(30px); transition: all 0.6s ease; }
        .fade-in.visible { opacity: 1; transform: translateY(0); }

        @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @keyframes fadeOut { to { opacity: 0; visibility: hidden; } }

        @media (max-width: 768px) {
            nav.main-nav { padding: 0 1rem; }
            .nav-links { display: none; }
            .container { padding: 0 1rem; }
        }
    </style>
</head>
<body>
    <nav class="main-nav">
        <div class="logo">Farm<span>Vision</span></div>
        <ul class="nav-links">
            <li><a href="{{ path('front_home') }}" class="{{ app.request.get('_route') == 'front_home' ? 'active' : '' }}">Accueil</a></li>
            <li><a href="{{ path('front_about') }}" class="{{ app.request.get('_route') == 'front_about' ? 'active' : '' }}">À propos</a></li>
            {% if is_granted('ROLE_USER') %}
            <li><a href="{{ path('front_equipement_index') }}" class="{{ (app.request.get('_route') starts with 'front_equipement') ? 'active' : '' }}">Équipements</a></li>
            <li><a href="{{ path('front_maintenance_index') }}" class="{{ (app.request.get('_route') starts with 'front_maintenance') ? 'active' : '' }}">Maintenances</a></li>
            <li class="has-dropdown">
                <a href="{{ path('front_culture_index') }}" class="{{ ((app.request.get('_route') starts with 'front_culture') or (app.request.get('_route') starts with 'front_parcelle')) ? 'active' : '' }}">🌱 Cultures & Parcelles</a>
                <div class="nav-dropdown">
                    <a href="{{ path('front_culture_index') }}">🌿 Cultures</a>
                    <a href="{{ path('front_parcelle_index') }}">🗺️ Parcelles</a>
                </div>
            </li>
            {% endif %}
        </ul>
        <div class="nav-actions">
            {% if app.user %}
            <div class="user-info">
                <span class="user-name">{{ app.user.prenom }} {{ app.user.nom }}</span>
                <div class="user-avatar">{{ app.user.prenom|first }}{{ app.user.nom|first }}</div>
            </div>
            {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('admin_dashboard') }}" class="btn-login">📊 Dashboard</a>
            {% elseif is_granted('ROLE_RESPONSABLE') %}
            <a href="{{ path('responsable_dashboard') }}" class="btn-login">📊 Dashboard</a>
            {% else %}
            <a href="{{ path('agriculteur_dashboard') }}" class="btn-login">👨‍🌾 Mon espace</a>
            {% endif %}
            <a href="{{ path('app_logout') }}" class="btn-logout">🚪 Déconnexion</a>
            {% else %}
            <a href="{{ path('app_login') }}" class="btn-login">🔑 Connexion</a>
            <a href="{{ path('app_register') }}" class="btn-signup">✨ Inscription</a>
            {% endif %}
        </div>
    </nav>

    {% set onCultureParcelle = (app.request.get('_route') starts with 'front_culture') or (app.request.get('_route') starts with 'front_parcelle') %}

    {% if onCultureParcelle %}
    <nav class="sub-nav">
        <a href="{{ path('front_culture_index') }}" class="{{ (app.request.get('_route') starts with 'front_culture') ? 'active' : '' }}">🌿 Cultures</a>
        <a href="{{ path('front_parcelle_index') }}" class="{{ (app.request.get('_route') starts with 'front_parcelle') ? 'active' : '' }}">🗺️ Parcelles</a>
    </nav>
    {% endif %}

    <main class="{{ onCultureParcelle ? 'with-subnav' : '' }}">
        {% block body %}{% endblock %}
    </main>

    <footer>
        <p>© 2025 FarmVision. Agriculture intelligente au service des agriculteurs.</p>
    </footer>

    {% for message in app.flashes('success') %}
    <div class="flash-message flash-success">✅ {{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
    <div class="flash-message flash-error">❌ {{ message }}</div>
    {% endfor %}

    <script>
        setTimeout(() => { document.querySelectorAll('.flash-message').forEach(msg => msg.remove()); }, 5000);
    </script>
</body>
</html>
