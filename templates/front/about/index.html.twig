<!-- JavaScript pour le défilement smooth, surlignage et animation fade-in -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    // ========== 1. DÉFILEMENT SMOOTH POUR LES ANCRES ==========
    const anchors = document.querySelectorAll('.nav-anchor');
    
    anchors.forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('href');
            const targetElement = document.querySelector(targetId);
            
            if (targetElement) {
                const offsetTop = targetElement.offsetTop - 140;
                window.scrollTo({
                    top: offsetTop,
                    behavior: 'smooth'
                });
                
                // Mettre à jour l'URL sans recharger
                history.pushState(null, null, targetId);
            }
        });
    });
    
    // ========== 2. ANIMATION FADE-IN AU SCROLL ==========
    const fadeElements = document.querySelectorAll('.fade-in');
    
    const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, observerOptions);
    
    fadeElements.forEach(el => observer.observe(el));
    
    // Activer les éléments déjà visibles au chargement
    fadeElements.forEach(el => {
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight - 100) {
            el.classList.add('visible');
        }
    });
    
    // ========== 3. SURlIGNER L'ANCRE ACTIVE LORS DU SCROLL ==========
    function highlightActiveAnchor() {
        const sections = document.querySelectorAll('section[id]');
        const scrollPosition = window.scrollY + 150;
        
        sections.forEach(section => {
            const sectionTop = section.offsetTop;
            const sectionBottom = sectionTop + section.offsetHeight;
            const sectionId = section.getAttribute('id');
            const anchor = document.querySelector(`.nav-anchor[href="#${sectionId}"]`);
            
            if (anchor) {
                if (scrollPosition >= sectionTop && scrollPosition < sectionBottom) {
                    anchor.style.color = 'var(--green-mid)';
                    anchor.style.borderBottom = '2px solid var(--green-mid)';
                    anchor.style.paddingBottom = '4px';
                } else {
                    anchor.style.color = 'var(--text-muted)';
                    anchor.style.borderBottom = 'none';
                }
            }
        });
    }
    
    window.addEventListener('scroll', highlightActiveAnchor);
    highlightActiveAnchor();
});
</script>

<style>
    .nav-anchor {
        transition: all 0.3s ease;
        position: relative;
    }
    
    .nav-anchor:hover {
        color: var(--green-mid) !important;
    }
    
    html {
        scroll-behavior: smooth;
    }
    
    section {
        scroll-margin-top: 100px;
    }
    
    /* Animation fade-in */
    .fade-in {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.6s ease;
    }
    
    .fade-in.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
