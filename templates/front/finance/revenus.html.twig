{% extends 'front/base.html.twig' %}

{% block body %}
<div class="container" style="padding: 3rem 0; max-width: 1200px; margin: 0 auto; padding: 3rem 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 0.5rem;">💰 Mes Revenus</h1>
            <p style="color: var(--text-muted);">Total: <strong style="color: var(--green-mid);">{{ total|number_format(2) }} DT</strong></p>
        </div>
        <a href="{{ path('front_finance_revenu_new') }}" class="btn-primary" style="padding: 0.75rem 1.5rem; text-decoration: none; background: var(--green-mid);">+ Nouveau revenu</a>
    </div>

    <!-- Search & Filter with Date Range -->
    <div class="card" style="margin-bottom: 2rem;">
        <form method="get">
            <div style="display: grid; grid-template-columns: 1fr auto auto auto auto; gap: 1rem; align-items: end;">
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem;">🔍 Rechercher</label>
                    <input type="text" name="search" value="{{ search }}" placeholder="Source ou description..." style="width: 100%; padding: 0.6rem; border-radius: 8px; border: 1px solid var(--border);">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem;">📂 Source</label>
                    <select name="source" style="padding: 0.6rem; border-radius: 8px; border: 1px solid var(--border);">
                        <option value="all" {% if selectedSource == 'all' %}selected{% endif %}>Toutes</option>
                        {% for source in sourceOptions %}
                            <option value="{{ source }}" {% if selectedSource == source %}selected{% endif %}>{{ source }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem;">📅 Date début</label>
                    <input type="date" name="start_date" value="{{ startDate }}" style="padding: 0.6rem; border-radius: 8px; border: 1px solid var(--border);">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem;">📅 Date fin</label>
                    <input type="date" name="end_date" value="{{ endDate }}" style="padding: 0.6rem; border-radius: 8px; border: 1px solid var(--border);">
                </div>
                <div>
                    <button type="submit" class="btn-primary" style="padding: 0.6rem 1.5rem;">Filtrer</button>
                    <a href="{{ path('front_finance_revenus') }}" style="margin-left: 0.5rem; padding: 0.6rem 1rem; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: var(--text-muted);">Réinitialiser</a>
                </div>
            </div>
        </form>
    </div>

    <!-- Display date range info -->
    {% if startDate or endDate %}
    <div style="margin-bottom: 1rem; padding: 0.5rem 1rem; background: var(--green-mist); border-radius: 8px;">
        📅 Période: 
        {% if startDate %}du {{ startDate|date('d/m/Y') }}{% endif %}
        {% if endDate %}au {{ endDate|date('d/m/Y') }}{% endif %}
        ({{ revenus|length }} résultat(s))
    </div>
    {% endif %}

    <!-- Revenus List -->
    {% if revenus|length > 0 %}
    <div class="card">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="text-align: left; padding: 0.75rem; background: var(--green-mist);">Date</th>
                    <th style="text-align: left; padding: 0.75rem; background: var(--green-mist);">Source</th>
                    <th style="text-align: left; padding: 0.75rem; background: var(--green-mist);">Description</th>
                    <th style="text-align: right; padding: 0.75rem; background: var(--green-mist);">Montant</th>
                    <th style="text-align: center; padding: 0.75rem; background: var(--green-mist);">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for revenu in revenus %}
                <tr>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border);">{{ revenu.dateRevenu|date('d/m/Y') }}</td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border);">
                        <span class="badge badge-success">{{ revenu.source }}</span>
                    </td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border);">{{ revenu.description|default('-')|slice(0, 50) }}</td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border); text-align: right; font-weight: 600; color: var(--green-mid);">
                        {{ revenu.montant|number_format(2) }} DT
                    </td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border); text-align: center;">
                        <a href="{{ path('front_finance_revenu_edit', {'id': revenu.idRevenu}) }}" style="margin-right: 0.5rem; text-decoration: none; color: var(--green-mid);">✏️</a>
                        <form method="post" action="{{ path('front_finance_revenu_delete', {'id': revenu.idRevenu}) }}" style="display: inline;" onsubmit="return confirm('Supprimer ce revenu ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ revenu.idRevenu) }}">
                            <button type="submit" style="background: none; border: none; color: var(--red); cursor: pointer;">🗑️</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="card" style="text-align: center; padding: 3rem;">
        <p>Aucun revenu trouvé pour cette période.</p>
        <a href="{{ path('front_finance_revenu_new') }}" class="btn-primary" style="margin-top: 1rem; display: inline-block; text-decoration: none; background: var(--green-mid);">Ajouter un revenu</a>
    </div>
    {% endif %}
</div>
{% endblock %}