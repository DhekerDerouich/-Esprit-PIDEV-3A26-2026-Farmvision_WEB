{% extends 'front/base.html.twig' %}

{% block body %}
<div class="container" style="padding: 3rem 0; max-width: 1400px; margin: 0 auto; padding: 3rem 2rem;">

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 0.5rem;">💸 Mes Dépenses</h1>
            <p style="color: var(--text-muted);">
                Total: <strong style="color: var(--red);">{{ totalTND|number_format(2) }} DT</strong>
                (≈ {{ totalEUR|number_format(2) }} € | ≈ {{ totalUSD|number_format(2) }} $)
            </p>
            <p style="color: var(--text-muted); font-size: 0.8rem;">{{ depenses.getTotalItemCount }} dépense(s) au total</p>
        </div>
        <a href="{{ path('front_finance_depense_new') }}" class="btn-primary" style="padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 8px;">+ Nouvelle dépense</a>
    </div>

    <!-- Taux de change en temps réel -->
    <div class="card" style="background: linear-gradient(135deg, var(--green-deep), var(--green-mid)); color: white; margin-bottom: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; padding: 0.5rem;">
            <div>
                <h4 style="margin-bottom: 0.25rem;">💱 Taux de change en temps réel</h4>
                <p style="opacity: 0.8; font-size: 0.75rem;">Dernière mise à jour: {{ 'now'|date('H:i:s') }}</p>
            </div>
            <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                <div style="text-align: center;">
                    <div style="font-size: 0.7rem; opacity: 0.8;">Euro (EUR)</div>
                    <div style="font-size: 1.5rem; font-weight: 700;">{{ eurRate.rate }}</div>
                    <div style="font-size: 0.7rem; {% if eurRate.is_up %}color: #90EE90;{% elseif eurRate.is_down %}color: #FFB6C1;{% endif %}">
                        {% if eurRate.is_up %}📈 +{{ eurRate.change }}%{% elseif eurRate.is_down %}📉 {{ eurRate.change }}%{% else %}➡️ 0%{% endif %}
                    </div>
                </div>
                <div style="text-align: center;">
                    <div style="font-size: 0.7rem; opacity: 0.8;">Dollar US (USD)</div>
                    <div style="font-size: 1.5rem; font-weight: 700;">{{ usdRate.rate }}</div>
                    <div style="font-size: 0.7rem; {% if usdRate.is_up %}color: #90EE90;{% elseif usdRate.is_down %}color: #FFB6C1;{% endif %}">
                        {% if usdRate.is_up %}📈 +{{ usdRate.change }}%{% elseif usdRate.is_down %}📉 {{ usdRate.change }}%{% else %}➡️ 0%{% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="card" style="background: white; border-radius: 12px; padding: 1.5rem; margin-bottom: 2rem;">
        <form method="get">
            <div style="display: grid; grid-template-columns: 1fr auto auto auto auto; gap: 1rem; align-items: end;">
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem;">🔍 Rechercher</label>
                    <input type="text" name="search" value="{{ search }}" placeholder="Type ou description..." style="width: 100%; padding: 0.6rem; border-radius: 8px; border: 1px solid var(--border);">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem;">📂 Type</label>
                    <select name="type" style="padding: 0.6rem; border-radius: 8px; border: 1px solid var(--border);">
                        <option value="all" {% if selectedType == 'all' %}selected{% endif %}>Tous</option>
                        {% for type in typeOptions %}
                            <option value="{{ type }}" {% if selectedType == type %}selected{% endif %}>{{ type }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem;">📅 Date début</label>
                    <input type="date" name="start_date" value="{{ startDate }}" style="padding: 0.6rem; border-radius: 8px; border: 1px solid var(--border);">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 0.5rem; font-size: 0.8rem;">📅 Date fin</label>
                    <input type="date" name="end_date" value="{{ endDate }}" style="padding: 0.6rem; border-radius: 8px; border: 1px solid var(--border);">
                </div>
                <div>
                    <button type="submit" class="btn-primary" style="padding: 0.6rem 1.5rem; border: none; border-radius: 8px; cursor: pointer;">Filtrer</button>
                    <a href="{{ path('front_finance_depenses') }}" style="margin-left: 0.5rem; padding: 0.6rem 1rem; border: 1px solid var(--border); border-radius: 8px; text-decoration: none;">Réinitialiser</a>
                </div>
            </div>
        </form>
    </div>

    <!-- Liste des dépenses -->
    {% if depenses|length > 0 %}
    <div class="card" style="background: white; border-radius: 12px; padding: 1.5rem;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="text-align: left; padding: 0.75rem; background: var(--green-mist);">Date</th>
                    <th style="text-align: left; padding: 0.75rem; background: var(--green-mist);">Type</th>
                    <th style="text-align: left; padding: 0.75rem; background: var(--green-mist);">Description</th>
                    <th style="text-align: right; padding: 0.75rem; background: var(--green-mist);">Montant (TND)</th>
                    <th style="text-align: right; padding: 0.75rem; background: var(--green-mist);">≈ EUR</th>
                    <th style="text-align: right; padding: 0.75rem; background: var(--green-mist);">≈ USD</th>
                    <th style="text-align: center; padding: 0.75rem; background: var(--green-mist);">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for depense in depenses %}
                <tr>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border);">{{ depense.dateDepense|date('d/m/Y') }}</td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border);">
                        <span class="badge badge-warning">{{ depense.typeDepense }}</span>
                    </td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border);">{{ depense.description|default('-')|slice(0, 50) }}</td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border); text-align: right; font-weight: 600; color: var(--red);">
                        {{ depense.montant|number_format(2) }} DT
                    </td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border); text-align: right; color: var(--gray);">
                        {{ (depense.montant * eurRate.rate)|number_format(2) }} €
                    </td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border); text-align: right; color: var(--gray);">
                        {{ (depense.montant * usdRate.rate)|number_format(2) }} $
                    </td>
                    <td style="padding: 0.75rem; border-bottom: 1px solid var(--border); text-align: center;">
                        <a href="{{ path('front_finance_depense_edit', {'id': depense.idDepense}) }}" style="margin-right: 0.5rem; text-decoration: none;">✏️</a>
                        <form method="post" action="{{ path('front_finance_depense_delete', {'id': depense.idDepense}) }}" style="display: inline;" onsubmit="return confirm('Supprimer cette dépense ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ depense.idDepense) }}">
                            <button type="submit" style="background: none; border: none; color: var(--red); cursor: pointer;">🗑️</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        
        <!-- PAGINATION -->
        <div style="margin-top: 2rem; text-align: center;">
            {{ knp_pagination_render(depenses) }}
        </div>
        
        <div style="margin-top: 1rem; text-align: center; color: var(--text-muted); font-size: 0.8rem;">
            Page {{ depenses.getCurrentPageNumber }} sur {{ depenses.getPageCount }}
        </div>
    </div>
    {% else %}
    <div class="card" style="background: white; border-radius: 12px; padding: 3rem; text-align: center;">
        <p>Aucune dépense trouvée.</p>
        <a href="{{ path('front_finance_depense_new') }}" class="btn-primary" style="margin-top: 1rem; display: inline-block; text-decoration: none; border-radius: 8px;">Ajouter une dépense</a>
    </div>
    {% endif %}
</div>
{% endblock %}