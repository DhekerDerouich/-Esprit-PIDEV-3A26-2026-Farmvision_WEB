{% extends 'front/base.html.twig' %}

{% block body %}
<div class="container" style="padding: 3rem 0; max-width: 800px; margin: 0 auto; padding: 3rem 2rem;">
    <div style="margin-bottom: 2rem;">
        <a href="{{ path('front_finance_revenus') }}" class="btn-outline btn" style="text-decoration: none;">← Retour</a>
    </div>

    <div class="card">
        <h1 style="font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 1.5rem;">➕ Ajouter un revenu</h1>
        
        <form method="post">
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Source du revenu *</label>
                <select name="source" class="form-control" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 8px;" required>
                    <option value="">-- Choisir une source --</option>
                    <option value="Vente récoltes">🌾 Vente de récoltes</option>
                    <option value="Vente animaux">🐄 Vente d'animaux</option>
                    <option value="Subventions">💰 Subventions</option>
                    <option value="Prestations">🚜 Prestations de services</option>
                    <option value="Location matériel">📦 Location de matériel</option>
                    <option value="Autre">📋 Autre</option>
                </select>
            </div>
            
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Montant (DT) *</label>
                <input type="number" name="montant" class="form-control" step="0.01" min="0.01" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 8px;" required>
            </div>
            
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Date de revenu *</label>
                <input type="date" name="date_revenu" class="form-control" value="{{ 'now'|date('Y-m-d') }}" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 8px;" required>
            </div>
            
            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 500;">Description</label>
                <textarea name="description" class="form-control" rows="3" style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 8px;"></textarea>
            </div>
            
            <button type="submit" class="btn-primary" style="padding: 0.75rem 2rem; border: none; border-radius: 8px; cursor: pointer; background: var(--green-mid);">💾 Enregistrer</button>
        </form>
    </div>
</div>
{% endblock %}