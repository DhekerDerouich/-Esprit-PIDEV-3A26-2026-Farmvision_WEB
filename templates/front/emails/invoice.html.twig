{# templates/emails/invoice.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Votre facture FarmVision</title>
</head>
<body style="font-family: Arial, sans-serif;">
    <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
        <div style="text-align: center; border-bottom: 2px solid #4CAF50; padding-bottom: 20px; margin-bottom: 20px;">
            <h1 style="color: #4CAF50;">FARM VISION</h1>
            <p>Merci pour votre achat !</p>
        </div>
        
        <p>Bonjour {{ invoice.customerName ?: 'Client' }},</p>
        
        <p>Nous vous confirmons votre commande. Vous trouverez ci-joint votre facture au format PDF.</p>
        
        <div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin: 20px 0;">
            <p><strong>Numéro de facture:</strong> {{ invoice.invoiceNumber }}</p>
            <p><strong>Montant total:</strong> {{ invoice.amount|number_format(2) }} {{ invoice.currency }}</p>
            <p><strong>Date:</strong> {{ invoice.createdAt|date('d/m/Y H:i') }}</p>
        </div>
        
        <p>Pour toute question, n'hésitez pas à nous contacter.</p>
        
        <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #ddd; text-align: center; font-size: 12px; color: #888;">
            <p>FarmVision - Solutions agricoles innovantes</p>
            <p>Tunis, Tunisie | contact@farmvision.com</p>
        </div>
    </div>
</body>
</html>