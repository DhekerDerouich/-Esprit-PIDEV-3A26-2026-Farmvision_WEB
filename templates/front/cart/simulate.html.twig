{% extends 'front/base.html.twig' %}

{% block body %}
<div class="container" style="padding: 3rem 0; max-width: 600px; margin: 0 auto;">

    <div style="text-align:center; margin-bottom: 2rem;">
        <div style="font-size: 3rem; margin-bottom: .5rem;">💳</div>
        <h1 style="font-family:'Playfair Display',serif; color: var(--green-deep);">Paiement simulé</h1>
        <p style="color: var(--text-muted);">Mode démonstration — aucun vrai paiement effectué</p>
    </div>

    {# Order summary #}
    <div class="card" style="margin-bottom: 1.5rem;">
        <h2 style="font-size:1rem; font-weight:600; margin-bottom:1rem; color:#333;">📦 Récapitulatif de commande</h2>
        <table style="width:100%; border-collapse:collapse; font-size:.9rem;">
            <thead>
                <tr style="border-bottom:2px solid #eee;">
                    <th style="padding:.5rem; text-align:left;">Produit</th>
                    <th style="padding:.5rem; text-align:right;">Qté</th>
                    <th style="padding:.5rem; text-align:right;">Prix</th>
                    <th style="padding:.5rem; text-align:right;">Total</th>
                </tr>
            </thead>
            <tbody>
                {% for item in cart.items %}
                <tr style="border-bottom:1px solid #f0f0f0;">
                    <td style="padding:.6rem .5rem;">{{ item.marketplace.stock.nomProduit }}</td>
                    <td style="padding:.6rem .5rem; text-align:right;">{{ item.quantity }}</td>
                    <td style="padding:.6rem .5rem; text-align:right;">{{ item.price|number_format(2) }} DT</td>
                    <td style="padding:.6rem .5rem; text-align:right; font-weight:600;">{{ item.total|number_format(2) }} DT</td>
                </tr>
                {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" style="padding:.75rem .5rem; text-align:right; font-weight:700; font-size:1rem;">Total à payer</td>
                    <td style="padding:.75rem .5rem; text-align:right; font-weight:700; font-size:1.2rem; color: var(--green-mid);">
                        {{ total|number_format(2) }} DT
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>

    {# Fake payment form #}
    <div class="card">
        <h2 style="font-size:1rem; font-weight:600; margin-bottom:1.25rem; color:#333;">💳 Informations de paiement (simulation)</h2>

        <form method="post" action="{{ path('front_cart_simulate_confirm') }}">

            {% if not app.user %}
            <div style="margin-bottom:1rem;">
                <label style="display:block; font-size:.85rem; font-weight:500; margin-bottom:.3rem;">Nom complet</label>
                <input type="text" name="name" class="form-control" placeholder="Jean Dupont" required
                       style="width:100%; padding:.55rem .75rem; border:1px solid #ddd; border-radius:8px; font-size:.9rem; box-sizing:border-box;">
            </div>
            <div style="margin-bottom:1rem;">
                <label style="display:block; font-size:.85rem; font-weight:500; margin-bottom:.3rem;">Email</label>
                <input type="email" name="email" class="form-control" placeholder="vous@exemple.com" required
                       style="width:100%; padding:.55rem .75rem; border:1px solid #ddd; border-radius:8px; font-size:.9rem; box-sizing:border-box;">
            </div>
            {% endif %}

            <div style="margin-bottom:1rem;">
                <label style="display:block; font-size:.85rem; font-weight:500; margin-bottom:.3rem;">Numéro de carte</label>
                <input type="text" value="4242 4242 4242 4242" readonly
                       style="width:100%; padding:.55rem .75rem; border:1px solid #ddd; border-radius:8px; font-size:.9rem; background:#f9f9f9; color:#888; box-sizing:border-box; cursor:not-allowed;">
                <span style="font-size:.75rem; color:#888;">Carte de test — aucun débit réel</span>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1.5rem;">
                <div>
                    <label style="display:block; font-size:.85rem; font-weight:500; margin-bottom:.3rem;">Date d'expiration</label>
                    <input type="text" value="12/26" readonly
                           style="width:100%; padding:.55rem .75rem; border:1px solid #ddd; border-radius:8px; font-size:.9rem; background:#f9f9f9; color:#888; box-sizing:border-box; cursor:not-allowed;">
                </div>
                <div>
                    <label style="display:block; font-size:.85rem; font-weight:500; margin-bottom:.3rem;">CVC</label>
                    <input type="text" value="123" readonly
                           style="width:100%; padding:.55rem .75rem; border:1px solid #ddd; border-radius:8px; font-size:.9rem; background:#f9f9f9; color:#888; box-sizing:border-box; cursor:not-allowed;">
                </div>
            </div>

            <div style="background:#e8f5e9; border-radius:8px; padding:.75rem 1rem; margin-bottom:1.5rem; font-size:.85rem; color:#2e7d32;">
                🔒 Paiement sécurisé simulé — vos données ne sont pas transmises
            </div>

            <button type="submit"
                    style="width:100%; background:#2d6a4f; color:white; padding:.85rem; border:none; border-radius:8px; font-size:1rem; font-weight:600; cursor:pointer; transition:background .2s;"
                    onmouseover="this.style.background='#1a3a2a'"
                    onmouseout="this.style.background='#2d6a4f'">
                ✅ Confirmer le paiement — {{ total|number_format(2) }} DT
            </button>

        </form>
    </div>

    <div style="text-align:center; margin-top:1rem;">
        <a href="{{ path('front_cart_index') }}" style="color: var(--text-muted); font-size:.85rem;">← Retour au panier</a>
    </div>

</div>
{% endblock %}
