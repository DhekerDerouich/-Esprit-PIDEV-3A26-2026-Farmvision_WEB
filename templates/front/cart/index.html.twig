{# templates/front/cart/index.html.twig #}
{% extends 'front/base.html.twig' %}

{% block body %}
<div class="container" style="padding: 3rem 0;">
    <h1 style="font-family: 'Playfair Display', serif;">🛒 Mon panier</h1>
    
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}
    
    {% if cart.items|length > 0 %}
        <div class="card" style="margin-bottom: 2rem; overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid #ddd;">
                        <th style="padding: 1rem; text-align: left;">Produit</th>
                        <th style="padding: 1rem; text-align: left;">Prix unitaire</th>
                        <th style="padding: 1rem; text-align: left;">Quantité</th>
                        <th style="padding: 1rem; text-align: left;">Total</th>
                        <th style="padding: 1rem;"></th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in cart.items %}
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 1rem;">
                            <strong>{{ item.marketplace.stock.nomProduit }}</strong>
                            {% if item.marketplace.description %}
                                <div style="font-size: 0.8rem; color: #888;">{{ item.marketplace.description|slice(0, 50) }}</div>
                            {% endif %}
                        </td>
                        <td style="padding: 1rem;">{{ item.price|number_format(2) }} DT</td>
                        <td style="padding: 1rem;">
                            <form method="post" action="{{ path('front_cart_update', {'id': item.id}) }}" style="display: flex; gap: 0.5rem;">
                                <input type="number" name="quantity" value="{{ item.quantity }}" min="1" max="{{ item.marketplace.quantiteEnVente }}" style="width: 80px; padding: 0.25rem;">
                                <button type="submit" class="btn-sm btn-outline">Mettre à jour</button>
                            </form>
                        </td>
                        <td style="padding: 1rem;"><strong>{{ item.total|number_format(2) }} DT</strong></td>
                        <td style="padding: 1rem;">
                            <form method="post" action="{{ path('front_cart_remove', {'id': item.id}) }}">
                                <button type="submit" class="btn-sm btn-danger" style="background: none; border: none; color: #dc3545; cursor: pointer;">🗑️</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" style="padding: 1rem; text-align: right;">
                            <strong>Total:</strong>
                        </td>
                        <td colspan="2" style="padding: 1rem;">
                            <strong style="font-size: 1.5rem; color: #4CAF50;">{{ total|number_format(2) }} DT</strong>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
        
        <div style="display: flex; gap: 1rem; justify-content: flex-end;">
            <a href="{{ path('front_marketplace_index') }}" class="btn-outline btn">Continuer les achats</a>
            <a href="{{ path('front_cart_checkout') }}" class="btn btn-primary">💰 Payer avec Stripe</a>
        </div>
    {% else %}
        <div class="card" style="text-align: center; padding: 3rem;">
            <div style="font-size: 4rem;">🛒</div>
            <p>Votre panier est vide</p>
            <a href="{{ path('front_marketplace_index') }}" class="btn btn-primary">Découvrir nos produits</a>
        </div>
    {% endif %}
</div>

<style>
    .alert-success { background: #d4edda; color: #155724; padding: 0.75rem; border-radius: 6px; margin-bottom: 1rem; }
    .alert-danger { background: #f8d7da; color: #721c24; padding: 0.75rem; border-radius: 6px; margin-bottom: 1rem; }
    .btn-sm { padding: 0.25rem 0.5rem; font-size: 0.8rem; }
    .btn-outline { background: none; border: 1px solid #4CAF50; color: #4CAF50; }
    .btn-outline:hover { background: #4CAF50; color: white; }
    .btn-danger { color: #dc3545; }
    .btn-danger:hover { color: #a71d2a; }
</style>
{% endblock %}