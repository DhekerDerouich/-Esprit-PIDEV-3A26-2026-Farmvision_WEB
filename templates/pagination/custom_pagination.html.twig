{#
/**
 * Template de pagination personnalisé pour FarmVision
 */
#}

{% if pageCount > 1 %}
<div class="pagination-wrapper">
    <div class="pagination-info">
        Page {{ current }} sur {{ pageCount }}
        ({{ totalCount }} résultats au total)
    </div>
    
    <ul class="pagination">
        {# Lien "Premier" #}
        {% if first is defined %}
            <li>
                <a href="{{ path(route, query|merge({(pageParameterName): first})) }}">
                    ⏮️ Premier
                </a>
            </li>
        {% else %}
            <li class="disabled">
                <span>⏮️ Premier</span>
            </li>
        {% endif %}

        {# Lien "Précédent" #}
        {% if previous is defined %}
            <li>
                <a href="{{ path(route, query|merge({(pageParameterName): previous})) }}">
                    ← Précédent
                </a>
            </li>
        {% else %}
            <li class="disabled">
                <span>← Précédent</span>
            </li>
        {% endif %}

        {# Pages numérotées #}
        {% for page in pagesInRange %}
            {% if page != current %}
                <li>
                    <a href="{{ path(route, query|merge({(pageParameterName): page})) }}">
                        {{ page }}
                    </a>
                </li>
            {% else %}
                <li class="active">
                    <span>{{ page }}</span>
                </li>
            {% endif %}
        {% endfor %}

        {# Lien "Suivant" #}
        {% if next is defined %}
            <li>
                <a href="{{ path(route, query|merge({(pageParameterName): next})) }}">
                    Suivant →
                </a>
            </li>
        {% else %}
            <li class="disabled">
                <span>Suivant →</span>
            </li>
        {% endif %}

        {# Lien "Dernier" #}
        {% if last is defined %}
            <li>
                <a href="{{ path(route, query|merge({(pageParameterName): last})) }}">
                    Dernier ⏭️
                </a>
            </li>
        {% else %}
            <li class="disabled">
                <span>Dernier ⏭️</span>
            </li>
        {% endif %}
    </ul>
</div>

<style>
.pagination-wrapper {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    text-align: center;
}

.pagination-info {
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--gray);
}

.pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
}

.pagination li {
    display: inline-block;
}

.pagination li a,
.pagination li span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
}

.pagination li a {
    background: white;
    color: var(--green-mid);
    border: 1px solid var(--border);
}

.pagination li a:hover {
    background: var(--green-mist);
    border-color: var(--green-mid);
    transform: translateY(-2px);
}

.pagination li.active span {
    background: linear-gradient(135deg, var(--green-mid), var(--green-light));
    color: white;
    border: none;
    box-shadow: 0 2px 8px rgba(45, 106, 79, 0.3);
}

.pagination li.disabled span {
    background: var(--gray-lighter);
    color: var(--gray-light);
    border: 1px solid var(--border);
    cursor: not-allowed;
}

@media (max-width: 768px) {
    .pagination li a,
    .pagination li span {
        min-width: 32px;
        height: 32px;
        padding: 0 0.5rem;
        font-size: 0.75rem;
    }
}
</style>
{% endif %}