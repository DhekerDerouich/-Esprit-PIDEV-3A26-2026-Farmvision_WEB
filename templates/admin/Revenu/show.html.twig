{% extends 'admin/base.html.twig' %}

{% block page_title %}Détail du revenu{% endblock %}

{% block body %}
<div class="card fade-in">
    <div class="card-header">
        <h3>📄 Détail du revenu #{{ revenu.idRevenu }}</h3>
        <div>
            <a href="{{ path('admin_revenu_edit', {'idRevenu': revenu.idRevenu}) }}" class="btn btn-primary">✏️ Modifier</a>
            <a href="{{ path('admin_revenu_index') }}" class="btn btn-outline">← Retour</a>
        </div>
    </div>
    
    <table style="width: 100%;">
        <tr>
            <th style="width: 200px; background: var(--gray-lighter); padding: 0.75rem;">ID</th>
            <td style="padding: 0.75rem;">{{ revenu.idRevenu }}</td>
        </tr>
        <tr>
            <th style="background: var(--gray-lighter); padding: 0.75rem;">Source</th>
            <td style="padding: 0.75rem;"><span class="badge badge-success">{{ revenu.source }}</span></td>
        </tr>
        <tr>
            <th style="background: var(--gray-lighter); padding: 0.75rem;">Montant</th>
            <td style="padding: 0.75rem;" class="text-success">{{ revenu.montant|number_format(2) }} DT</td>
        </tr>
        <tr>
            <th style="background: var(--gray-lighter); padding: 0.75rem;">Date</th>
            <td style="padding: 0.75rem;">{{ revenu.dateRevenu|date('d/m/Y') }}</td>
        </tr>
        <tr>
            <th style="background: var(--gray-lighter); padding: 0.75rem;">Description</th>
            <td style="padding: 0.75rem;">{{ revenu.description|default('-') }}</td>
        </tr>
        <tr>
            <th style="background: var(--gray-lighter); padding: 0.75rem;">Créé le</th>
            <td style="padding: 0.75rem;">{{ revenu.createdAt|date('d/m/Y H:i') }}</td>
        </tr>
    </table>
</div>
{% endblock %}