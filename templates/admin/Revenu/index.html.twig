{% extends 'admin/base.html.twig' %}

{% block page_title %}Gestion des Revenus - Admin{% endblock %}

{% block body %}
<div class="fade-in">
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">💰</div>
            <div class="stat-value">{{ totalRevenus|number_format(2) }} DT</div>
            <div class="stat-label">Total des revenus</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📋</div>
            <div class="stat-value">{{ revenus.getTotalItemCount }}</div>
            <div class="stat-label">Nombre total</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>🔍 Filtres</h3>
        </div>
        <form method="get" class="search-bar">
            <input type="text" name="search" class="search-input" value="{{ search }}" placeholder="Rechercher...">

            <select name="responsable" class="search-input">
                <option value="all">Tous les responsables</option>
                {% for responsable in responsables %}
                    <option value="{{ responsable.id }}" {% if selectedResponsable == responsable.id %}selected{% endif %}>
                        {{ responsable.prenom }} {{ responsable.nom }} ({{ responsable.email }})
                    </option>
                {% endfor %}
            </select>

            <select name="source" class="search-input">
                <option value="all">Toutes les sources</option>
                {% for src in sourceOptions %}
                    <option value="{{ src }}" {% if selectedSource == src %}selected{% endif %}>{{ src }}</option>
                {% endfor %}
            </select>

            <input type="date" name="start_date" class="search-input" value="{{ startDate }}" placeholder="Date début">
            <input type="date" name="end_date" class="search-input" value="{{ endDate }}" placeholder="Date fin">

            <button type="submit" class="btn btn-primary">🔍 Filtrer</button>
            <a href="{{ path('admin_revenu_index') }}" class="btn btn-outline">🔄 Réinitialiser</a>
        </form>
    </div>

    <div class="card">
        <h3>📋 Liste des revenus</h3>

        {% if revenus|length > 0 %}
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Responsable</th>
                    <th>Source</th>
                    <th>Montant</th>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for revenu in revenus %}
                <tr>
                    <td>#{{ revenu.idRevenu }}</td>
                    <td>
                        {% if revenu.userId and responsablesMap[revenu.userId] is defined %}
                            <strong>{{ responsablesMap[revenu.userId].prenom }} {{ responsablesMap[revenu.userId].nom }}</strong><br>
                            <small style="color: var(--gray);">{{ responsablesMap[revenu.userId].email }}</small>
                        {% else %}
                            <span class="badge badge-warning">Utilisateur inconnu</span>
                            <small>(ID: {{ revenu.userId }})</small>
                        {% endif %}
                    </td>
                    <td><span class="badge badge-success">{{ revenu.source }}</span></td>
                    <td class="text-success">{{ revenu.montant|number_format(2) }} DT</td>
                    <td>{{ revenu.dateRevenu|date('d/m/Y') }}</td>
                    <td>{{ revenu.description|slice(0, 50) }}{% if revenu.description|length > 50 %}...{% endif %}</td>
                    <td style="white-space: nowrap;">
                        <a href="{{ path('admin_revenu_show', {'id': revenu.idRevenu}) }}" class="btn btn-sm btn-outline" style="margin-right: 5px;">👁️</a>
                        <form method="post" action="{{ path('admin_revenu_delete', {'id': revenu.idRevenu}) }}" style="display:inline" onsubmit="return confirm('Supprimer ce revenu ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ revenu.idRevenu) }}">
                            <button type="submit" class="btn btn-sm btn-outline" style="color: var(--red);">🗑️</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div style="text-align: center; padding: 3rem; color: var(--gray);">
            <p>Aucun revenu trouvé.</p>
        </div>
        {% endif %}

        <div class="pagination-container" style="margin-top: 2rem;">
            {{ knp_pagination_render(revenus) }}
        </div>
    </div>
</div>
{% endblock %}