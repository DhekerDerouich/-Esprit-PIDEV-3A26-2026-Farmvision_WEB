{% extends 'admin/base.html.twig' %}

{% block page_title %}Détails de la culture{% endblock %}

{% block body %}
<div style="margin-bottom: 1.5rem;">
    <a href="{{ path('admin_culture_index') }}" class="btn btn-outline">
        <i class="fas fa-arrow-left"></i> Retour
    </a>
    <a href="{{ path('admin_culture_edit', {idCulture: culture.idCulture}) }}" class="btn btn-primary">
        <i class="fas fa-edit"></i> Modifier
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h3>🌱 {{ culture.nomCulture }}</h3>
    </div>

    <table class="data-table">
        <tr>
            <th style="width: 200px;">Nom de la culture</th>
            <td>{{ culture.nomCulture }}</td>
        </tr>
        <tr>
            <th>Type</th>
            <td>{{ culture.typeCulture }}</td>
        </tr>
        <tr>
            <th>Date de semis</th>
            <td>{{ culture.dateSemis ? culture.dateSemis|date('d/m/Y') : '-' }}</td>
        </tr>
        <tr>
            <th>Date de récolte</th>
            <td>{{ culture.dateRecolte ? culture.dateRecolte|date('d/m/Y') : '-' }}</td>
        </tr>
        <tr>
            <th>Statut</th>
            <td>
                {% if culture.dateRecolte and culture.dateRecolte <= date() %}
                    <span class="badge badge-success">✅ Récoltée</span>
                {% elseif culture.dateRecolte and culture.dateRecolte > date() %}
                    <span class="badge badge-info">📅 Récolte prévue le {{ culture.dateRecolte|date('d/m/Y') }}</span>
                {% else %}
                    <span class="badge badge-warning">🌱 En cours (pas de date de récolte prévue)</span>
                {% endif %}
            </td>
        </tr>
    </table>
</div>
{% endblock %}
