{% extends 'admin/base.html.twig' %}
{% block page_title %}IA — Statistiques Utilisateurs{% endblock %}

{% block body %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
.ai-header{background:#1a1a2e;border-radius:16px;padding:2rem;margin-bottom:1.5rem;color:white}
.ai-title{font-size:1.5rem;font-weight:700;display:flex;align-items:center;gap:.75rem;margin-bottom:.25rem}
.ai-badge{background:#10b981;color:white;font-size:.7rem;padding:.2rem .75rem;border-radius:20px;font-weight:600;letter-spacing:1px}
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem}
.kpi{background:white;border-radius:12px;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,.08);text-align:center}
.kpi-val{font-size:2rem;font-weight:700;color:#1a1a2e}
.kpi-lbl{font-size:.75rem;color:#64748b;margin-top:.25rem}
.kpi-sub{font-size:.7rem;margin-top:.2rem;font-weight:600}
.charts-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;margin-bottom:1.5rem}
.chart-card{background:white;border-radius:12px;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,.08)}
.chart-title{font-size:.9rem;font-weight:600;color:#1a1a2e;margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
.chart-wrap{height:260px;position:relative}
.full-card{background:white;border-radius:12px;padding:1.25rem;box-shadow:0 1px 4px rgba(0,0,0,.08);margin-bottom:1rem}
.pred-row{display:flex;align-items:center;justify-content:space-between;padding:.6rem 0;border-bottom:1px solid #f1f5f9}
.pred-mois{font-weight:600;font-size:.9rem}
.pred-val{font-size:1.1rem;font-weight:700;color:#2d6a4f}
.trend-up{color:#10b981}.trend-down{color:#ef4444}.trend-stable{color:#f59e0b}
</style>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem">
    <h1 style="font-size:1.4rem">🤖 IA — Statistiques Utilisateurs</h1>
    <a href="{{ path('admin_user_index') }}" style="padding:.5rem 1rem;border:1px solid #ddd;border-radius:8px;font-size:.85rem;text-decoration:none;color:#333">← Retour utilisateurs</a>
</div>

<div class="ai-header">
    <div class="ai-title">
        <span>📊</span> Analyse prédictive des inscriptions
        <span class="ai-badge">RÉGRESSION LINÉAIRE</span>
    </div>
    <p style="opacity:.75;font-size:.9rem;margin:0">Prédictions basées sur les 12 derniers mois d'inscriptions réelles</p>
</div>

{# KPIs #}
<div class="kpi-grid">
    <div class="kpi">
        <div class="kpi-val">{{ totalUsers }}</div>
        <div class="kpi-lbl">Utilisateurs total</div>
    </div>
    <div class="kpi">
        <div class="kpi-val">{{ previsionProchainMois }}</div>
        <div class="kpi-lbl">Prévision mois prochain</div>
        <div class="kpi-sub {% if tendance == 'hausse' %}trend-up{% elseif tendance == 'baisse' %}trend-down{% else %}trend-stable{% endif %}">
            Tendance : {{ tendance }}
        </div>
    </div>
    <div class="kpi">
        <div class="kpi-val {% if tauxCroissance > 0 %}trend-up{% elseif tauxCroissance < 0 %}trend-down{% else %}trend-stable{% endif %}">
            {% if tauxCroissance is not null %}{{ tauxCroissance > 0 ? '+' : '' }}{{ tauxCroissance }}%{% else %}N/A{% endif %}
        </div>
        <div class="kpi-lbl">Croissance ce mois</div>
    </div>
    <div class="kpi">
        <div class="kpi-val">{{ predictionsSum }}</div>
        <div class="kpi-lbl">Total prévu (6 mois)</div>
    </div>
</div>

{# Charts #}
<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-title">📈 Inscriptions réelles (12 mois)</div>
        <div class="chart-wrap"><canvas id="chartInscriptions"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="chart-title">🔮 Prévisions IA (6 mois)</div>
        <div class="chart-wrap"><canvas id="chartPredictions"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="chart-title">⚥ Répartition par genre</div>
        <div class="chart-wrap"><canvas id="chartGenre"></canvas></div>
    </div>
    <div class="chart-card">
        <div class="chart-title">🎂 Répartition par tranche d'âge</div>
        <div class="chart-wrap"><canvas id="chartAge"></canvas></div>
    </div>
</div>

{# Tableau prédictions #}
<div class="full-card">
    <div class="chart-title">🗓️ Détail des prévisions mensuelles</div>
    {% for mois, val in predictions %}
    <div class="pred-row">
        <span class="pred-mois">{{ mois }}</span>
        <span class="pred-val">{{ val }} inscription{{ val > 1 ? 's' : '' }} prévue{{ val > 1 ? 's' : '' }}</span>
    </div>
    {% endfor %}
</div>

<script>
const inscLabels = {{ inscriptionsMoisLabels|json_encode|raw }};
const inscData   = {{ inscriptionsMoisValues|json_encode|raw }};
const predLabels = {{ predictionsLabels|json_encode|raw }};
const predData   = {{ predictionsValues|json_encode|raw }};
const genreData  = {{ genresValues|json_encode|raw }};
const ageLabels  = {{ tranchesLabels|json_encode|raw }};
const ageData    = {{ tranchesValues|json_encode|raw }};

const defaults = { responsive:true, maintainAspectRatio:false, plugins:{ legend:{ display:false } } };

new Chart(document.getElementById('chartInscriptions'), {
    type:'bar',
    data:{ labels:inscLabels, datasets:[{
        label:'Inscriptions', data:inscData,
        backgroundColor:'#2d6a4f', borderRadius:6
    }]},
    options:{ ...defaults, scales:{ y:{ beginAtZero:true, ticks:{ stepSize:1 } } } }
});

new Chart(document.getElementById('chartPredictions'), {
    type:'line',
    data:{ labels:predLabels, datasets:[{
        label:'Prévisions IA', data:predData,
        borderColor:'#10b981', backgroundColor:'rgba(16,185,129,.1)',
        fill:true, tension:.4, pointRadius:5, pointBackgroundColor:'#10b981'
    }]},
    options:{ ...defaults, plugins:{ legend:{ display:false } }, scales:{ y:{ beginAtZero:true, ticks:{ stepSize:1 } } } }
});

new Chart(document.getElementById('chartGenre'), {
    type:'doughnut',
    data:{ labels:['Masculin','Féminin','Autre','Non renseigné'], datasets:[{
        data:genreData,
        backgroundColor:['#3b82f6','#ec4899','#8b5cf6','#94a3b8'],
        borderWidth:0
    }]},
    options:{ ...defaults, plugins:{ legend:{ display:true, position:'bottom' } }, cutout:'60%' }
});

new Chart(document.getElementById('chartAge'), {
    type:'bar',
    data:{ labels:ageLabels, datasets:[{
        label:'Utilisateurs', data:ageData,
        backgroundColor:['#f59e0b','#10b981','#3b82f6','#8b5cf6','#ec4899','#ef4444','#94a3b8'],
        borderRadius:6
    }]},
    options:{ ...defaults, scales:{ y:{ beginAtZero:true, ticks:{ stepSize:1 } } } }
});
</script>
{% endblock %}
