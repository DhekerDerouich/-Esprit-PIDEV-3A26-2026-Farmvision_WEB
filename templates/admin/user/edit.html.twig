{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier utilisateur{% endblock %}

{% block body %}
<div style="margin-bottom: 2rem;">
    <a href="{{ path('admin_user_index') }}" class="btn" style="background: var(--bg-panel);">← Retour</a>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h1 style="font-size: 1.5rem; margin-bottom: 1.5rem;">✏️ Modifier {{ user.prenom }} {{ user.nom }}</h1>
    
    <form method="post">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label>Nom</label>
                <input type="text" name="nom" value="{{ user.nom }}" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Prénom</label>
                <input type="text" name="prenom" value="{{ user.prenom }}" class="form-control" required>
            </div>
        </div>
        
        <div class="form-group">
            <label>Email</label>
            <input type="email" name="email" value="{{ user.email }}" class="form-control" required>
        </div>
        
        <div class="form-group">
            <label>Téléphone</label>
            <input type="tel" name="telephone" value="{{ user.telephone }}" class="form-control">
        </div>
        
        <div class="form-group">
            <label>Adresse</label>
            <input type="text" name="adresse" value="{{ user.adresse }}" class="form-control">
        </div>
        
        <div class="form-group">
            <label>Rôle</label>
            <select name="type_role" class="form-control">
                <option value="AGRICULTEUR" {% if user.typeRole == 'AGRICULTEUR' %}selected{% endif %}>🌾 Agriculteur</option>
                <option value="RESPONSABLE_EXPLOITATION" {% if user.typeRole == 'RESPONSABLE_EXPLOITATION' %}selected{% endif %}>📋 Responsable d'exploitation</option>
                <option value="ADMINISTRATEUR" {% if user.typeRole == 'ADMINISTRATEUR' %}selected{% endif %}>👑 Administrateur</option>
            </select>
        </div>
        
        <div class="form-group">
            <label>
                <input type="checkbox" name="activated" value="1" {% if user.activated %}checked{% endif %}> Compte actif
            </label>
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
            <a href="{{ path('admin_user_index') }}" class="btn" style="background: var(--bg-panel);">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}