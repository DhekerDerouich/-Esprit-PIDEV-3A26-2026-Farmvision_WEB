{# templates/admin/voice_chat/index.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block page_title %}Assistant Vocal FarmVision{% endblock %}

{% block body %}
<style>
:root {
    --voice-primary: #10b981;
    --voice-primary-dark: #059669;
    --voice-dark: #1e293b;
    --voice-gray: #64748b;
}

.voice-chat-container {
    max-width: 900px;
    margin: 2rem auto;
    background: white;
    border-radius: 28px;
    padding: 0;
    box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.15);
    overflow: hidden;
    border: 1px solid #e2e8f0;
}

.chat-header {
    background: linear-gradient(135deg, var(--voice-primary), var(--voice-primary-dark));
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.chat-header h2 {
    color: white;
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.chat-header h2::before {
    content: '🎤';
    font-size: 1.5rem;
}

.status {
    padding: 0.35rem 1rem;
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(255, 255, 255, 0.2);
    color: white;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.status::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    display: inline-block;
    animation: pulse-green 2s infinite;
}

.status.recording::before {
    background: #dc2626;
    animation: pulse-red 1s infinite;
}

@keyframes pulse-green {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

@keyframes pulse-red {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.2); }
}

.chat-messages {
    height: 450px;
    overflow-y: auto;
    padding: 1.5rem;
    background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
}

.chat-messages::-webkit-scrollbar {
    width: 6px;
}

.chat-messages::-webkit-scrollbar-track {
    background: #e2e8f0;
    border-radius: 10px;
}

.chat-messages::-webkit-scrollbar-thumb {
    background: var(--voice-primary);
    border-radius: 10px;
}

.message {
    margin-bottom: 1rem;
    padding: 0.875rem 1.125rem;
    border-radius: 20px;
    max-width: 75%;
    animation: slideIn 0.3s ease;
    white-space: pre-line;
}

@keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.message.user {
    background: linear-gradient(135deg, var(--voice-primary), var(--voice-primary-dark));
    color: white;
    margin-left: auto;
    border-bottom-right-radius: 4px;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);
}

.message.bot {
    background: white;
    color: var(--voice-dark);
    margin-right: auto;
    border-bottom-left-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    border: 1px solid #e2e8f0;
}

.voice-controls {
    display: flex;
    justify-content: center;
    padding: 1.5rem;
    background: white;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
}

.btn-mic {
    background: linear-gradient(135deg, #dc2626, #991b1b);
    color: white;
    border: none;
    padding: 1rem 2rem;
    border-radius: 60px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    box-shadow: 0 4px 15px rgba(220, 38, 38, 0.3);
}

.btn-mic:hover {
    transform: scale(1.05);
}

.btn-mic.recording {
    background: linear-gradient(135deg, #ef4444, #dc2626);
    animation: micPulse 1.5s infinite;
}

@keyframes micPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
}

.input-area {
    padding: 1.25rem 1.5rem;
    background: white;
}

.text-input {
    display: flex;
    gap: 0.75rem;
    align-items: center;
}

.text-input input {
    flex: 1;
    padding: 0.875rem 1.25rem;
    border: 2px solid #e2e8f0;
    border-radius: 60px;
    font-size: 0.9rem;
}

.text-input input:focus {
    outline: none;
    border-color: var(--voice-primary);
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
}

.btn-send {
    background: linear-gradient(135deg, var(--voice-primary), var(--voice-primary-dark));
    color: white;
    border: none;
    padding: 0.875rem 1.75rem;
    border-radius: 60px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.btn-send:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
}

.example-questions {
    padding: 1rem 1.5rem 1.5rem;
    background: white;
    border-top: 1px solid #e2e8f0;
}

.example-questions h4 {
    font-size: 0.75rem;
    color: var(--voice-gray);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.questions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
}

.example-btn {
    background: linear-gradient(135deg, #f8fafc, #f1f5f9);
    border: 1px solid #e2e8f0;
    padding: 0.5rem 1rem;
    border-radius: 40px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    color: var(--voice-dark);
}

.example-btn:hover {
    background: linear-gradient(135deg, var(--voice-primary), var(--voice-primary-dark));
    border-color: transparent;
    color: white;
    transform: translateY(-2px);
}

.waveform-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    height: 40px;
    margin-left: 1rem;
}

.waveform-bar {
    width: 4px;
    background: var(--voice-primary);
    border-radius: 2px;
    transition: height 0.1s ease;
}

.typing-indicator {
    display: flex;
    gap: 4px;
    padding: 0.5rem 0;
}

.typing-indicator span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--voice-gray);
    animation: typing 1.4s infinite;
}

.typing-indicator span:nth-child(2) {
    animation-delay: 0.2s;
}

.typing-indicator span:nth-child(3) {
    animation-delay: 0.4s;
}

@keyframes typing {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.7; }
    30% { transform: translateY(-10px); opacity: 1; }
}

@media (max-width: 768px) {
    .voice-chat-container { margin: 1rem; border-radius: 16px; }
    .message { max-width: 90%; }
    .chat-messages { height: 350px; padding: 1rem; }
    .btn-mic { padding: 0.75rem 1.5rem; font-size: 0.9rem; }
}
</style>

<div class="voice-chat-container">
    <div class="chat-header">
        <h2>Assistant Vocal FarmVision</h2>
        <div class="status" id="status">🟢 Prêt</div>
    </div>
    
    <div class="chat-messages" id="messages">
        <div class="message bot">
            <strong>🤖 Assistant:</strong> Bonjour ! Je suis votre assistant vocal FarmVision.<br>
            🎤 Cliquez sur le microphone et parlez, ou tapez votre question ci-dessous.
        </div>
    </div>
    
    <div class="voice-controls">
        <button class="btn-mic" id="micBtn">🎤 Parler</button>
        <div class="waveform-container" id="waveform">
            <div class="waveform-bar" style="height: 10px;"></div>
            <div class="waveform-bar" style="height: 20px;"></div>
            <div class="waveform-bar" style="height: 15px;"></div>
            <div class="waveform-bar" style="height: 25px;"></div>
            <div class="waveform-bar" style="height: 12px;"></div>
            <div class="waveform-bar" style="height: 18px;"></div>
            <div class="waveform-bar" style="height: 22px;"></div>
        </div>
    </div>
    
    <div class="input-area">
        <div class="text-input">
            <input type="text" id="textInput" placeholder="Tapez votre message ici...">
            <button class="btn-send" id="sendBtn">📤 Envoyer</button>
        </div>
    </div>
    
    <div class="example-questions">
        <h4>💡 Suggestions</h4>
        <div class="questions">
            <button class="example-btn" onclick="setQuestion('nombre')">📊 Nombre équipements</button>
            <button class="example-btn" onclick="setQuestion('maintenances urgentes')">⚠️ Maintenances urgentes</button>
            <button class="example-btn" onclick="setQuestion('équipements en panne')">🔴 Équipements en panne</button>
            <button class="example-btn" onclick="setQuestion('liste des équipements')">📋 Liste équipements</button>
            <button class="example-btn" onclick="setQuestion('coût')">💰 Coûts</button>
            <button class="example-btn" onclick="setQuestion('bilan')">📈 Bilan</button>
            <button class="example-btn" onclick="setQuestion('aide')">🆘 Aide</button>
        </div>
    </div>
</div>

<script>
    let recognition = null;
    let isRecording = false;
    let lastTranscript = '';
    let processingMessage = false;
    
    document.addEventListener('DOMContentLoaded', function() {
        initSpeechRecognition();
        initWaveform();
        
        document.getElementById('micBtn').addEventListener('click', toggleRecording);
        document.getElementById('sendBtn').addEventListener('click', sendTextMessage);
        document.getElementById('textInput').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') sendTextMessage();
        });
    });
    
    function initWaveform() {
        const bars = document.querySelectorAll('.waveform-bar');
        setInterval(() => {
            if (isRecording) {
                bars.forEach(bar => {
                    const height = Math.random() * 30 + 5;
                    bar.style.height = height + 'px';
                });
            } else {
                bars.forEach(bar => bar.style.height = '8px');
            }
        }, 150);
    }
    
    function initSpeechRecognition() {
        if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            recognition = new SpeechRecognition();
            recognition.continuous = false;
            recognition.interimResults = true;
            recognition.lang = 'fr-FR';
            
            recognition.onstart = function() {
                isRecording = true;
                lastTranscript = '';
                document.getElementById('micBtn').classList.add('recording');
                document.getElementById('micBtn').innerHTML = '🔴 Parlez...';
                document.getElementById('status').className = 'status recording';
                document.getElementById('status').innerHTML = '🔴 Enregistrement...';
            };
            
            recognition.onend = function() {
                isRecording = false;
                document.getElementById('micBtn').classList.remove('recording');
                document.getElementById('micBtn').innerHTML = '🎤 Parler';
                document.getElementById('status').className = 'status';
                document.getElementById('status').innerHTML = '🟢 Prêt';
            };
            
            recognition.onresult = function(event) {
                let finalTranscript = '';
                for (let i = event.resultIndex; i < event.results.length; i++) {
                    if (event.results[i].isFinal) {
                        finalTranscript = event.results[i][0].transcript;
                    }
                }
                
                if (finalTranscript && finalTranscript !== lastTranscript && !processingMessage) {
                    lastTranscript = finalTranscript;
                    document.getElementById('textInput').value = finalTranscript;
                    sendMessage(finalTranscript);
                }
            };
            
            recognition.onerror = function(event) {
                if (event.error === 'not-allowed') {
                    addMessage('bot', '⚠️ Veuillez autoriser l\'accès au microphone.');
                } else if (event.error !== 'no-speech') {
                    addMessage('bot', '⚠️ Je n\'ai pas bien compris. Pouvez-vous répéter ?');
                }
                recognition.stop();
            };
        } else {
            document.getElementById('status').innerHTML = '⚠️ Non supporté';
            document.getElementById('micBtn').disabled = true;
            document.getElementById('micBtn').style.opacity = '0.5';
            addMessage('bot', '⚠️ Votre navigateur ne supporte pas la reconnaissance vocale. Utilisez le texte.');
        }
    }
    
    function toggleRecording() {
        if (recognition) {
            if (isRecording) {
                recognition.stop();
            } else {
                lastTranscript = '';
                recognition.start();
            }
        }
    }
    
    async function sendTextMessage() {
        const input = document.getElementById('textInput');
        const message = input.value.trim();
        if (message && !processingMessage) {
            sendMessage(message);
            input.value = '';
        }
    }
    
    async function sendMessage(message) {
        if (processingMessage) return;
        processingMessage = true;
        
        addMessage('user', message);
        showTypingIndicator();
        
        try {
            const response = await fetch('{{ path('admin_voice_chat_ask') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: message })
            });
            const data = await response.json();
            hideTypingIndicator();
            addMessage('bot', data.response);
            speakResponse(data.response);
        } catch (error) {
            hideTypingIndicator();
            addMessage('bot', '❌ Erreur, veuillez réessayer.');
        } finally {
            processingMessage = false;
        }
    }
    
    function speakResponse(text) {
        if ('speechSynthesis' in window) {
            window.speechSynthesis.cancel();
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = 'fr-FR';
            utterance.rate = 0.9;
            utterance.pitch = 1;
            window.speechSynthesis.speak(utterance);
        }
    }
    
    function addMessage(type, text) {
        const messagesDiv = document.getElementById('messages');
        const messageDiv = document.createElement('div');
        messageDiv.className = `message ${type}`;
        messageDiv.innerHTML = type === 'user' 
            ? `<strong>👤 Vous:</strong> ${text}`
            : `<strong>🤖 Assistant:</strong> ${text}`;
        messagesDiv.appendChild(messageDiv);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }
    
    let typingIndicator = null;
    
    function showTypingIndicator() {
        hideTypingIndicator();
        const messagesDiv = document.getElementById('messages');
        typingIndicator = document.createElement('div');
        typingIndicator.className = 'message bot';
        typingIndicator.id = 'typingIndicator';
        typingIndicator.innerHTML = '<div class="typing-indicator"><span></span><span></span><span></span></div>';
        messagesDiv.appendChild(typingIndicator);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }
    
    function hideTypingIndicator() {
        if (typingIndicator) {
            typingIndicator.remove();
            typingIndicator = null;
        }
    }
    
    function setQuestion(question) {
        if (!processingMessage) {
            document.getElementById('textInput').value = question;
            sendTextMessage();
        }
    }
</script>
{% endblock %}
