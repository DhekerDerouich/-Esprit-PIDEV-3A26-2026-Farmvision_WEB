{# templates/admin/base.html.twig - Version moderne avec menu déroulant #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmVision - Administration</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --primary: #10b981;
            --primary-dark: #059669;
            --primary-light: #34d399;
            --secondary: #6366f1;
            --secondary-dark: #4f46e5;
            --dark: #1e293b;
            --darker: #0f172a;
            --gray: #64748b;
            --gray-light: #94a3b8;
            --gray-lighter: #e2e8f0;
            --light: #f8fafc;
            --white: #ffffff;
            --danger: #ef4444;
            --warning: #f59e0b;
            --success: #10b981;
            --info: #3b82f6;
            --sidebar-w: 280px;
            --header-h: 70px;
            --radius: 12px;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }

        /* Dark Theme */
        body.dark-theme {
            --dark: #e2e8f0;
            --darker: #f1f5f9;
            --gray: #94a3b8;
            --gray-light: #64748b;
            --gray-lighter: #334155;
            --light: #0f172a;
            --white: #1e293b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            overflow-x: hidden;
            transition: background 0.3s, color 0.3s;
        }

        /* Sidebar moderne */
        .sidebar {
            width: var(--sidebar-w);
            background: linear-gradient(135deg, var(--darker) 0%, var(--dark) 100%);
            position: fixed;
            left: 0;
            top: 0;
            height: 100%;
            z-index: 100;
            transition: all 0.3s ease;
            overflow-y: auto;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 1.5rem;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .logo-text {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--white);
        }

        .logo-text span {
            color: var(--primary);
        }

        .sidebar-menu {
            list-style: none;
            padding: 0 1rem;
        }

        .sidebar-menu li {
            margin-bottom: 0.5rem;
        }

        .sidebar-menu li a {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border-radius: var(--radius);
            color: var(--gray-light);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
        }

        .sidebar-menu li a i {
            width: 20px;
            font-size: 1.1rem;
        }

        .sidebar-menu li a:hover {
            background: rgba(255,255,255,0.05);
            color: var(--white);
        }

        .sidebar-menu li.active a {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: var(--white);
            box-shadow: var(--shadow-md);
        }

        /* Main content */
        .main-content {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
        }

        /* Top bar */
        .top-bar {
            background: var(--white);
            padding: 0 2rem;
            height: var(--header-h);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--gray-lighter);
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .page-title {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--dark), var(--gray));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* User menu dropdown */
        .user-menu {
            position: relative;
            display: flex;
            align-items: center;
            gap: 1rem;
            cursor: pointer;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: 50%;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-weight: 600;
        }

        .avatar-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .user-name {
            color: var(--gray);
            font-weight: 500;
        }

        .dropdown-arrow {
            font-size: 0.7rem;
            color: var(--gray);
            transition: transform 0.3s;
        }

        .user-dropdown {
            position: absolute;
            top: 100%;
            right: 0;
            margin-top: 0.5rem;
            background: var(--white);
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            min-width: 240px;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
            z-index: 100;
            border: 1px solid var(--gray-lighter);
        }

        .user-menu.active .user-dropdown {
            opacity: 1;
            visibility: visible;
        }

        .user-menu.active .dropdown-arrow {
            transform: rotate(180deg);
        }

        .dropdown-header {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--gray-lighter);
        }

        .dropdown-header .name {
            font-weight: 700;
            color: var(--dark);
        }

        .dropdown-header .email {
            font-size: 0.7rem;
            color: var(--gray);
            margin-top: 0.25rem;
        }

        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            text-decoration: none;
            color: var(--dark);
            transition: background 0.2s;
        }

        .dropdown-item:hover {
            background: var(--gray-lighter);
        }

        .dropdown-item i {
            width: 20px;
            color: var(--primary);
        }

        .theme-switch {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            border-top: 1px solid var(--gray-lighter);
            border-bottom: 1px solid var(--gray-lighter);
        }

        .theme-buttons {
            display: flex;
            gap: 0.5rem;
        }

        .theme-btn {
            padding: 0.25rem 0.5rem;
            border-radius: 6px;
            border: 1px solid var(--gray-lighter);
            background: var(--white);
            cursor: pointer;
            transition: all 0.2s;
        }

        .theme-btn:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .dropdown-divider {
            height: 1px;
            background: var(--gray-lighter);
            margin: 0;
        }

        .dropdown-item.logout {
            color: var(--danger);
        }

        .dropdown-item.logout i {
            color: var(--danger);
        }

        /* Content */
        .content {
            padding: 2rem;
        }

        /* Cards modernes */
        .card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            transition: all 0.3s;
            border: 1px solid var(--gray-lighter);
        }

        .card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .card-header h3 {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--dark);
        }

        /* Statistiques cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-lighter);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
        }

        .stat-icon {
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            color: var(--dark);
            line-height: 1;
        }

        .stat-label {
            color: var(--gray);
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        /* Tableaux modernes */
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            text-align: left;
            padding: 1rem;
            background: var(--gray-lighter);
            color: var(--dark);
            font-weight: 600;
            font-size: 0.875rem;
        }

        .data-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--gray-lighter);
            color: var(--gray);
        }

        .data-table tr:hover td {
            background: var(--light);
        }

        /* Badges */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge-success { background: #d1fae5; color: #065f46; }
        .badge-warning { background: #fed7aa; color: #92400e; }
        .badge-danger { background: #fee2e2; color: #991b1b; }
        .badge-info { background: #dbeafe; color: #1e40af; }

        /* Boutons */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: var(--radius);
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
            cursor: pointer;
            border: none;
            font-size: 0.875rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: var(--white);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .btn-secondary {
            background: var(--secondary);
            color: var(--white);
        }

        .btn-outline {
            border: 1px solid var(--gray-lighter);
            background: var(--white);
            color: var(--gray);
        }

        .btn-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
        }

        /* Formulaires */
        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
            color: var(--dark);
        }

        .form-control {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid var(--gray-lighter);
            border-radius: var(--radius);
            font-size: 0.875rem;
            transition: all 0.2s;
            background: var(--white);
            color: var(--dark);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
        }

        textarea.form-control {
            resize: vertical;
        }

        /* Search bar */
        .search-bar {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .search-input {
            flex: 1;
            padding: 0.75rem 1rem;
            border: 1px solid var(--gray-lighter);
            border-radius: var(--radius);
            font-size: 0.875rem;
            background: var(--white);
            color: var(--dark);
        }

        /* Flash messages */
        .flash-message {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 1000;
            padding: 1rem 1.5rem;
            border-radius: var(--radius);
            font-weight: 500;
            animation: slideIn 0.3s ease;
        }

        .flash-success {
            background: #d1fae5;
            color: #065f46;
            border-left: 4px solid var(--success);
        }

        .flash-error {
            background: #fee2e2;
            color: #991b1b;
            border-left: 4px solid var(--danger);
        }

        .flash-warning {
            background: #fed7aa;
            color: #92400e;
            border-left: 4px solid var(--warning);
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Text colors */
        .text-success { color: var(--success); }
        .text-danger { color: var(--danger); }
        .text-warning { color: var(--warning); }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.3s ease;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
            }
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .user-name {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon">🌱</div>
                <div class="logo-text">Farm<span>Vision</span></div>
            </div>
        </div>
        <ul class="sidebar-menu">
<!-- DASHBOARD -->
        <li class="{{ app.request.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
            <a href="{{ path('admin_dashboard') }}"><i class="fas fa-chart-line"></i> Dashboard</a>
        </li>

        <!-- SECTION IA PRÉDICTIVE -->
        <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
            <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">🤖 Intelligence Artificielle</span>
        </li>
        <li class="{{ app.request.get('_route') starts with 'admin_predictive' ? 'active' : '' }}">
            <a href="{{ path('admin_predictive_index') }}"><i class="fas fa-brain"></i> IA Prédictive</a>
        </li>

        <!-- SECTION ÉQUIPEMENTS & MAINTENANCES -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">🚜 Parc matériel</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_equipement' ? 'active' : '' }}">
                <a href="{{ path('admin_equipement_index') }}"><i class="fas fa-tractor"></i> Équipements</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_maintenance' ? 'active' : '' }}">
                <a href="{{ path('admin_maintenance_index') }}"><i class="fas fa-wrench"></i> Maintenances</a>
            </li>
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">🤖 Outils IA</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_voice_chat' ? 'active' : '' }}">
                <a href="{{ path('admin_voice_chat') }}"><i class="fas fa-microphone"></i> Assistant Vocal</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_carbone' ? 'active' : '' }}">
                <a href="{{ path('admin_carbone_index') }}"><i class="fas fa-leaf"></i> Empreinte Carbone</a>
            </li>
            
            <!-- SECTION CULTURES & PARCELLES -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">🌾 Agriculture</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_culture' ? 'active' : '' }}">
                <a href="{{ path('admin_culture_index') }}"><i class="fas fa-seedling"></i> Cultures</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_parcelle' ? 'active' : '' }}">
                <a href="{{ path('admin_parcelle_index') }}"><i class="fas fa-map-marked-alt"></i> Parcelles</a>
            </li>
            
            <!-- SECTION FINANCES -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">💰 Finances</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_depense' ? 'active' : '' }}">
                <a href="{{ path('admin_depense_index') }}"><i class="fas fa-money-bill-wave"></i> Dépenses</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_revenu' ? 'active' : '' }}">
                <a href="{{ path('admin_revenu_index') }}"><i class="fas fa-chart-line"></i> Revenus</a>
            </li>
            
            <!-- SECTION GESTION DES STOCKS & MARKETPLACE -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">📦 Commercial</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_stock' ? 'active' : '' }}">
                <a href="{{ path('admin_stock_index') }}"><i class="fas fa-boxes"></i> Stocks</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_marketplace' ? 'active' : '' }}">
                <a href="{{ path('admin_marketplace_index') }}"><i class="fas fa-store"></i> Marketplace</a>
            </li>
            
<!-- SECTION RAPPORTS -->
        <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
            <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">📊 Rapports</span>
        </li>
        <li class="{{ app.request.get('_route') starts with 'admin_rapport' ? 'active' : '' }}">
            <a href="{{ path('admin_rapport_index') }}"><i class="fas fa-file-alt"></i> Rapports personnalisés</a>
        </li>

        <!-- SECTION UTILISATEURS -->
        <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
            <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">👥 Administration</span>
        </li>
        <li class="{{ app.request.get('_route') starts with 'admin_user' ? 'active' : '' }}">
            <a href="{{ path('admin_user_index') }}"><i class="fas fa-users"></i> Utilisateurs</a>
        </li>
        </ul>
    </div>

    <div class="main-content">
        <div class="top-bar">
            <h1 class="page-title">{% block page_title %}Dashboard{% endblock %}</h1>
            
            <!-- Maintenance Alert Bell -->
            <button class="maint-bell" id="maintBell" onclick="toggleMaintAlerts()" title="Alertes maintenance">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <span class="maint-badge hidden" id="maintBadge">0</span>
            </button>

            <!-- Menu utilisateur déroulant -->
            <div class="user-menu" id="userMenu">
                <div class="user-info">
                    <span class="user-name">{{ app.user.prenom }} {{ app.user.nom }}</span>
                    {{ include('profile/_avatar.html.twig', {
                        user: app.user,
                        wrapperClass: 'user-avatar',
                        fallbackText: app.user.prenom|first ~ app.user.nom|first,
                        alt: 'Photo de profil de ' ~ app.user.prenom ~ ' ' ~ app.user.nom
                    }) }}
                    <span class="dropdown-arrow">▼</span>
                </div>
                
                <div class="user-dropdown">
                    <div class="dropdown-header">
                        <div class="name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                        <div class="email">{{ app.user.email }}</div>
                    </div>
                    
                    <a href="{{ path('profile_show') }}" class="dropdown-item">
                        <i class="fas fa-user"></i> Mon profil
                    </a>
                    
                    <a href="{{ path('profile_edit') }}" class="dropdown-item">
                        <i class="fas fa-cog"></i> Paramètres
                    </a>
                    
                    <div class="theme-switch">
                        <span><i class="fas fa-moon"></i> Thème</span>
                        <div class="theme-buttons">
                            <button onclick="setTheme('light')" class="theme-btn">☀️</button>
                            <button onclick="setTheme('dark')" class="theme-btn">🌙</button>
                        </div>
                    </div>
                    
                    <div class="dropdown-divider"></div>
                    
                    <a href="{{ path('app_logout') }}" class="dropdown-item logout">
                        <i class="fas fa-sign-out-alt"></i> Déconnexion
                    </a>
                </div>
            </div>
        </div>
        
        <div class="content">
            <!-- Flash messages -->
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-message flash-{{ label }}">
                        {% if label == 'success' %}✅ {% elseif label == 'error' %}❌ {% elseif label == 'warning' %}⚠️ {% endif %}
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
            
            {% block body %}{% endblock %}
        </div>
    </div>

    <script>
        // Toggle dropdown menu
        const userMenu = document.getElementById('userMenu');
        userMenu.addEventListener('click', function(e) {
            e.stopPropagation();
            this.classList.toggle('active');
        });
        
        // Fermer le dropdown en cliquant ailleurs
        document.addEventListener('click', function() {
            userMenu.classList.remove('active');
        });
        
        // Thème Dark/Light
        function setTheme(theme) {
            if (theme === 'dark') {
                document.body.classList.add('dark-theme');
                localStorage.setItem('theme', 'dark');
            } else {
                document.body.classList.remove('dark-theme');
                localStorage.setItem('theme', 'light');
            }
        }
        
        // Charger le thème sauvegardé
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark-theme');
        }
        
        // Supprimer les messages flash après 5 secondes
        setTimeout(() => {
            document.querySelectorAll('.flash-message').forEach(msg => {
                msg.style.opacity = '0';
                msg.style.transform = 'translateX(100%)';
                setTimeout(() => msg.remove(), 300);
            });
        }, 5000);
        
        // Active link detection
        document.querySelectorAll('.sidebar-menu li a').forEach(link => {
            const currentPath = window.location.pathname;
            const linkPath = link.getAttribute('href');
            if (linkPath && currentPath === linkPath) {
                link.closest('li').classList.add('active');
            }
        });
    </script>

    <!-- ===== MAINTENANCE ALERT BELL STYLES ===== -->
    <style>
    .maint-bell {
        position: relative;
        width: 42px; height: 42px;
        border-radius: 50%;
        border: none;
        background: var(--gray-lighter);
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        color: var(--gray);
        transition: all .2s;
        margin-right: .75rem;
        flex-shrink: 0;
    }
    .maint-bell:hover { background: var(--primary); color: #fff; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(16,185,129,.35); }
    .maint-bell.has-alerts { background: #fef3c7; color: #d97706; }
    .maint-bell.has-urgent { background: #fee2e2; color: #dc2626; animation: bellShake .6s ease infinite; }
    @keyframes bellShake { 0%,100%{transform:rotate(0)} 20%{transform:rotate(-12deg)} 40%{transform:rotate(12deg)} 60%{transform:rotate(-8deg)} 80%{transform:rotate(8deg)} }
    .maint-badge {
        position: absolute; top: -4px; right: -4px;
        min-width: 20px; height: 20px; padding: 0 5px;
        background: #ef4444; color: #fff;
        border-radius: 10px; font-size: 11px; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        border: 2px solid #fff;
        animation: pulseBadge 2s infinite;
    }
    .maint-badge.hidden { display: none; }
    @keyframes pulseBadge { 0%,100%{transform:scale(1)} 50%{transform:scale(1.15)} }

    /* Alert Panel */
    #maintPanel {
        position: fixed; top: 75px; right: 20px;
        width: 380px; max-height: 560px;
        background: #fff; border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0,0,0,.18);
        z-index: 9999; overflow: hidden;
        transform: translateY(-10px) scale(.97);
        opacity: 0; visibility: hidden;
        transition: all .25s cubic-bezier(.4,0,.2,1);
        border: 1px solid rgba(0,0,0,.06);
    }
    #maintPanel.open { transform: translateY(0) scale(1); opacity: 1; visibility: visible; }
    .mp-header {
        background: linear-gradient(135deg,#1e293b,#334155);
        color: #fff; padding: 1rem 1.25rem;
        display: flex; justify-content: space-between; align-items: center;
    }
    .mp-header h4 { margin: 0; font-size: .95rem; font-weight: 600; }
    .mp-close { background: rgba(255,255,255,.15); border: none; color: #fff; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-size: 1.1rem; display: flex; align-items: center; justify-content: center; }
    .mp-close:hover { background: rgba(255,255,255,.3); }
    .mp-stats { display: flex; gap: .5rem; padding: .75rem 1rem; background: #f8fafc; border-bottom: 1px solid #e2e8f0; }
    .mp-stat { flex: 1; text-align: center; padding: .4rem; border-radius: 8px; font-size: .75rem; font-weight: 600; }
    .mp-stat.urgent { background: #fee2e2; color: #dc2626; }
    .mp-stat.warning { background: #fef3c7; color: #d97706; }
    .mp-stat.info { background: #dbeafe; color: #2563eb; }
    .mp-list { max-height: 400px; overflow-y: auto; padding: .5rem; }
    .mp-item {
        display: flex; gap: .75rem; padding: .85rem;
        margin-bottom: .4rem; border-radius: 10px;
        border-left: 4px solid; cursor: pointer;
        transition: all .15s; text-decoration: none; color: inherit;
    }
    .mp-item:hover { transform: translateX(-3px); box-shadow: 0 4px 12px rgba(0,0,0,.1); }
    .mp-item.URGENT { border-color: #dc2626; background: #fff5f5; }
    .mp-item.WARNING { border-color: #d97706; background: #fffbeb; }
    .mp-item.INFO { border-color: #2563eb; background: #eff6ff; }
    .mp-icon { font-size: 1.4rem; flex-shrink: 0; }
    .mp-body { flex: 1; min-width: 0; }
    .mp-title { font-size: .82rem; font-weight: 600; color: #1e293b; margin-bottom: .2rem; }
    .mp-msg { font-size: .75rem; color: #64748b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .mp-empty { text-align: center; padding: 2rem; color: #94a3b8; font-size: .85rem; }
    .mp-footer { padding: .75rem 1rem; border-top: 1px solid #e2e8f0; text-align: center; }
    .mp-footer a { font-size: .8rem; color: #10b981; text-decoration: none; font-weight: 500; }
    .mp-footer a:hover { text-decoration: underline; }

    /* Toast */
    .maint-toast {
        position: fixed; top: 80px; right: 20px;
        width: 340px; background: #fff;
        border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,.15);
        display: flex; gap: .75rem; padding: 1rem;
        z-index: 10000; border-left: 4px solid;
        transform: translateX(380px); opacity: 0;
        transition: all .3s ease;
    }
    .maint-toast.show { transform: translateX(0); opacity: 1; }
    .maint-toast.URGENT { border-color: #dc2626; }
    .maint-toast.WARNING { border-color: #d97706; }
    .maint-toast.INFO { border-color: #2563eb; }
    .maint-toast-icon { font-size: 1.5rem; flex-shrink: 0; }
    .maint-toast-body { flex: 1; }
    .maint-toast-body strong { display: block; font-size: .85rem; color: #1e293b; margin-bottom: .2rem; }
    .maint-toast-body p { margin: 0; font-size: .78rem; color: #64748b; }
    .maint-toast-close { background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 1.1rem; padding: 0; align-self: flex-start; }
    </style>

    <!-- ===== MAINTENANCE ALERT PANEL HTML ===== -->
    <div id="maintPanel">
        <div class="mp-header">
            <h4>🔧 Alertes Maintenance</h4>
            <button class="mp-close" onclick="toggleMaintAlerts()">×</button>
        </div>
        <div class="mp-stats" id="maintStats"></div>
        <div class="mp-list" id="maintList"><div class="mp-empty">Chargement...</div></div>
        <div class="mp-footer"><a href="/admin/maintenances/">Voir toutes les maintenances →</a></div>
    </div>

    <!-- ===== MAINTENANCE ALERT JS ===== -->
    <script>
    (function() {
        var panelOpen = false;
        var lastCount = 0;
        var shownToasts = new Set(JSON.parse(localStorage.getItem('shownMaintToasts') || '[]'));

        function toggleMaintAlerts() {
            panelOpen = !panelOpen;
            document.getElementById('maintPanel').classList.toggle('open', panelOpen);
            if (panelOpen) loadAlerts();
        }
        window.toggleMaintAlerts = toggleMaintAlerts;

        // Close panel when clicking outside
        document.addEventListener('click', function(e) {
            var panel = document.getElementById('maintPanel');
            var bell  = document.getElementById('maintBell');
            if (panelOpen && !panel.contains(e.target) && !bell.contains(e.target)) {
                panelOpen = false;
                panel.classList.remove('open');
            }
        });

        function loadAlerts() {
            fetch('/admin/api/alertes')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data.success) return;
                    renderStats(data.stats);
                    renderList(data.alertes);
                    updateBell(data.stats);
                    showNewToasts(data.alertes);
                })
                .catch(function() {});
        }

        function renderStats(stats) {
            var el = document.getElementById('maintStats');
            if (!el) return;
            el.innerHTML =
                '<div class="mp-stat urgent">🔴 ' + (stats.urgentes || 0) + ' Urgent</div>' +
                '<div class="mp-stat warning">🟡 ' + (stats.warnings || 0) + ' Warning</div>' +
                '<div class="mp-stat info">🔵 ' + (stats.infos || 0) + ' Info</div>';
        }

        function renderList(alertes) {
            var el = document.getElementById('maintList');
            if (!el) return;
            if (!alertes || alertes.length === 0) {
                el.innerHTML = '<div class="mp-empty">✅ Aucune alerte active</div>';
                return;
            }
            el.innerHTML = alertes.slice(0, 15).map(function(a) {
                return '<a class="mp-item ' + a.type + '" href="' + (a.lien || '#') + '">' +
                    '<div class="mp-icon">' + (a.icone || '🔧') + '</div>' +
                    '<div class="mp-body">' +
                        '<div class="mp-title">' + escHtml(a.titre) + '</div>' +
                        '<div class="mp-msg">' + escHtml(a.message) + '</div>' +
                    '</div></a>';
            }).join('');
        }

        function updateBell(stats) {
            var bell  = document.getElementById('maintBell');
            var badge = document.getElementById('maintBadge');
            var total = stats.total || 0;
            if (total > 0) {
                badge.textContent = total > 99 ? '99+' : total;
                badge.classList.remove('hidden');
                bell.classList.remove('has-alerts', 'has-urgent');
                bell.classList.add(stats.urgentes > 0 ? 'has-urgent' : 'has-alerts');
            } else {
                badge.classList.add('hidden');
                bell.classList.remove('has-alerts', 'has-urgent');
            }
        }

        function showNewToasts(alertes) {
            if (!alertes) return;
            var urgent = alertes.filter(function(a) { return a.type === 'URGENT'; });
            urgent.slice(0, 2).forEach(function(a) {
                if (!shownToasts.has(a.id)) {
                    showToast(a);
                    shownToasts.add(a.id);
                    localStorage.setItem('shownMaintToasts', JSON.stringify([...shownToasts]));
                }
            });
        }

        function showToast(alert) {
            var toast = document.createElement('div');
            toast.className = 'maint-toast ' + alert.type;
            toast.innerHTML =
                '<div class="maint-toast-icon">' + (alert.icone || '🔧') + '</div>' +
                '<div class="maint-toast-body">' +
                    '<strong>' + escHtml(alert.titre) + '</strong>' +
                    '<p>' + escHtml(alert.message) + '</p>' +
                '</div>' +
                '<button class="maint-toast-close" onclick="this.closest(\'.maint-toast\').remove()">×</button>';
            document.body.appendChild(toast);
            setTimeout(function() { toast.classList.add('show'); }, 50);
            setTimeout(function() {
                toast.classList.remove('show');
                setTimeout(function() { toast.remove(); }, 300);
            }, 6000);
        }

        function escHtml(str) {
            return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        // Load on page ready
        document.addEventListener('DOMContentLoaded', function() {
            loadAlerts();
            // Refresh every 2 minutes
            setInterval(loadAlerts, 120000);
        });
    }());
    </script>
</body>
</html>
