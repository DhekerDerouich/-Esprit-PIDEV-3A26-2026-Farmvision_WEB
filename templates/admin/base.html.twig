{# templates/admin/base.html.twig - Version moderne avec menu déroulant #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmVision - Administration</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        :root {
            --primary: #10b981;
            --primary-dark: #059669;
            --primary-light: #34d399;
            --secondary: #6366f1;
            --secondary-dark: #4f46e5;
            --dark: #1e293b;
            --darker: #0f172a;
            --gray: #64748b;
            --gray-light: #94a3b8;
            --gray-lighter: #e2e8f0;
            --light: #f8fafc;
            --white: #ffffff;
            --danger: #ef4444;
            --warning: #f59e0b;
            --success: #10b981;
            --info: #3b82f6;
            --sidebar-w: 280px;
            --header-h: 70px;
            --radius: 12px;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
        }

        /* Dark Theme */
        body.dark-theme {
            --dark: #e2e8f0;
            --darker: #f1f5f9;
            --gray: #94a3b8;
            --gray-light: #64748b;
            --gray-lighter: #334155;
            --light: #0f172a;
            --white: #1e293b;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            overflow-x: hidden;
            transition: background 0.3s, color 0.3s;
        }

        /* Sidebar moderne */
        .sidebar {
            width: var(--sidebar-w);
            background: linear-gradient(135deg, var(--darker) 0%, var(--dark) 100%);
            position: fixed;
            left: 0;
            top: 0;
            height: 100%;
            z-index: 100;
            transition: all 0.3s ease;
            overflow-y: auto;
        }

        .sidebar-header {
            padding: 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 1.5rem;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .logo-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: var(--radius);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .logo-text {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--white);
        }

        .logo-text span {
            color: var(--primary);
        }

        .sidebar-menu {
            list-style: none;
            padding: 0 1rem;
        }

        .sidebar-menu li {
            margin-bottom: 0.5rem;
        }

        .sidebar-menu li a {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            border-radius: var(--radius);
            color: var(--gray-light);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.2s;
        }

        .sidebar-menu li a i {
            width: 20px;
            font-size: 1.1rem;
        }

        .sidebar-menu li a:hover {
            background: rgba(255,255,255,0.05);
            color: var(--white);
        }

        .sidebar-menu li.active a {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: var(--white);
            box-shadow: var(--shadow-md);
        }

        /* Main content */
        .main-content {
            margin-left: var(--sidebar-w);
            min-height: 100vh;
        }

        /* Top bar */
        .top-bar {
            background: var(--white);
            padding: 0 2rem;
            height: var(--header-h);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--gray-lighter);
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .page-title {
            font-size: 1.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--dark), var(--gray));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Alertes notification bell */
        .alert-bell {
            position: relative;
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 50%;
            transition: background 0.2s;
        }

        .alert-bell:hover {
            background: var(--gray-lighter);
        }

        .alert-bell i {
            font-size: 1.25rem;
            color: var(--gray);
        }

        .alert-badge {
            position: absolute;
            top: 0;
            right: 0;
            background: var(--danger);
            color: white;
            font-size: 0.65rem;
            font-weight: 700;
            padding: 0.15rem 0.4rem;
            border-radius: 999px;
            min-width: 18px;
            text-align: center;
        }

        .alert-dropdown {
            position: absolute;
            top: 100%;
            right: 0;
            margin-top: 0.5rem;
            background: var(--white);
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            width: 400px;
            max-height: 500px;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
            z-index: 100;
            border: 1px solid var(--gray-lighter);
            overflow: hidden;
        }

        .alert-bell.active .alert-dropdown {
            opacity: 1;
            visibility: visible;
        }

        .alert-header {
            padding: 1rem;
            border-bottom: 1px solid var(--gray-lighter);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .alert-header h3 {
            font-size: 1rem;
            font-weight: 600;
        }

        .alert-list {
            max-height: 400px;
            overflow-y: auto;
        }

        .alert-item {
            padding: 1rem;
            border-bottom: 1px solid var(--gray-lighter);
            cursor: pointer;
            transition: background 0.2s;
        }

        .alert-item:hover {
            background: var(--light);
        }

        .alert-item.unread {
            background: rgba(16, 185, 129, 0.05);
        }

        .alert-item-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.25rem;
        }

        .alert-item-title {
            font-weight: 600;
            font-size: 0.875rem;
            color: var(--dark);
        }

        .alert-item-message {
            font-size: 0.8rem;
            color: var(--gray);
            margin-top: 0.25rem;
        }

        .alert-item-time {
            font-size: 0.7rem;
            color: var(--gray-light);
            margin-top: 0.25rem;
        }

        .alert-empty {
            padding: 3rem 1rem;
            text-align: center;
            color: var(--gray);
        }

        /* User menu dropdown */
        .user-menu {
            position: relative;
            display: flex;
            align-items: center;
            gap: 1rem;
            cursor: pointer;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--white);
            font-weight: 600;
        }

        .user-name {
            color: var(--gray);
            font-weight: 500;
        }

        .dropdown-arrow {
            font-size: 0.7rem;
            color: var(--gray);
            transition: transform 0.3s;
        }

        .user-dropdown {
            position: absolute;
            top: 100%;
            right: 0;
            margin-top: 0.5rem;
            background: var(--white);
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            min-width: 240px;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s;
            z-index: 100;
            border: 1px solid var(--gray-lighter);
        }

        .user-menu.active .user-dropdown {
            opacity: 1;
            visibility: visible;
        }

        .user-menu.active .dropdown-arrow {
            transform: rotate(180deg);
        }

        .dropdown-header {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--gray-lighter);
        }

        .dropdown-header .name {
            font-weight: 700;
            color: var(--dark);
        }

        .dropdown-header .email {
            font-size: 0.7rem;
            color: var(--gray);
            margin-top: 0.25rem;
        }

        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem 1rem;
            text-decoration: none;
            color: var(--dark);
            transition: background 0.2s;
        }

        .dropdown-item:hover {
            background: var(--gray-lighter);
        }

        .dropdown-item i {
            width: 20px;
            color: var(--primary);
        }

        .theme-switch {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            border-top: 1px solid var(--gray-lighter);
            border-bottom: 1px solid var(--gray-lighter);
        }

        .theme-buttons {
            display: flex;
            gap: 0.5rem;
        }

        .theme-btn {
            padding: 0.25rem 0.5rem;
            border-radius: 6px;
            border: 1px solid var(--gray-lighter);
            background: var(--white);
            cursor: pointer;
            transition: all 0.2s;
        }

        .theme-btn:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .dropdown-divider {
            height: 1px;
            background: var(--gray-lighter);
            margin: 0;
        }

        .dropdown-item.logout {
            color: var(--danger);
        }

        .dropdown-item.logout i {
            color: var(--danger);
        }

        /* Content */
        .content {
            padding: 2rem;
        }

        /* Cards modernes */
        .card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            box-shadow: var(--shadow);
            transition: all 0.3s;
            border: 1px solid var(--gray-lighter);
        }

        .card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .card-header h3 {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--dark);
        }

        /* Statistiques cards */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 1.5rem;
            box-shadow: var(--shadow);
            border: 1px solid var(--gray-lighter);
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
        }

        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
        }

        .stat-icon {
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            color: var(--dark);
            line-height: 1;
        }

        .stat-label {
            color: var(--gray);
            font-size: 0.875rem;
            margin-top: 0.5rem;
        }

        /* Tableaux modernes */
        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table th {
            text-align: left;
            padding: 1rem;
            background: var(--gray-lighter);
            color: var(--dark);
            font-weight: 600;
            font-size: 0.875rem;
        }

        .data-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--gray-lighter);
            color: var(--gray);
        }

        .data-table tr:hover td {
            background: var(--light);
        }

        /* Badges */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .badge-success { background: #d1fae5; color: #065f46; }
        .badge-warning { background: #fed7aa; color: #92400e; }
        .badge-danger { background: #fee2e2; color: #991b1b; }
        .badge-info { background: #dbeafe; color: #1e40af; }

        /* Boutons */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            border-radius: var(--radius);
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
            cursor: pointer;
            border: none;
            font-size: 0.875rem;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: var(--white);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .btn-secondary {
            background: var(--secondary);
            color: var(--white);
        }

        .btn-outline {
            border: 1px solid var(--gray-lighter);
            background: var(--white);
            color: var(--gray);
        }

        .btn-outline:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
        }

        /* Formulaires */
        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
            color: var(--dark);
        }

        .form-control {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid var(--gray-lighter);
            border-radius: var(--radius);
            font-size: 0.875rem;
            transition: all 0.2s;
            background: var(--white);
            color: var(--dark);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
        }

        textarea.form-control {
            resize: vertical;
        }

        /* Search bar */
        .search-bar {
            display: flex;
            gap: 1rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .search-input {
            flex: 1;
            padding: 0.75rem 1rem;
            border: 1px solid var(--gray-lighter);
            border-radius: var(--radius);
            font-size: 0.875rem;
            background: var(--white);
            color: var(--dark);
        }

        /* Flash messages */
        .flash-message {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 1000;
            padding: 1rem 1.5rem;
            border-radius: var(--radius);
            font-weight: 500;
            animation: slideIn 0.3s ease;
        }

        .flash-success {
            background: #d1fae5;
            color: #065f46;
            border-left: 4px solid var(--success);
        }

        .flash-error {
            background: #fee2e2;
            color: #991b1b;
            border-left: 4px solid var(--danger);
        }

        .flash-warning {
            background: #fed7aa;
            color: #92400e;
            border-left: 4px solid var(--warning);
        }

        /* Alert Toast Notifications */
        .alert-toast-container {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 2000;
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 400px;
        }

        .alert-toast {
            background: #ef4444;
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            animation: slideInRight 0.3s ease;
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            min-width: 350px;
        }

        .alert-toast.warning {
            background: #f59e0b;
        }

        .alert-toast.info {
            background: #10b981;
        }

        .alert-toast-icon {
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .alert-toast-content {
            flex: 1;
        }

        .alert-toast-title {
            font-weight: 700;
            font-size: 1rem;
            margin-bottom: 0.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .alert-toast-message {
            font-size: 0.875rem;
            opacity: 0.95;
            line-height: 1.4;
        }

        .alert-toast-close {
            background: none;
            border: none;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            padding: 0;
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0.8;
            transition: opacity 0.2s;
            flex-shrink: 0;
        }

        .alert-toast-close:hover {
            opacity: 1;
        }

        @keyframes slideInRight {
            from {
                transform: translateX(400px);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        @keyframes slideOutRight {
            from {
                transform: translateX(0);
                opacity: 1;
            }
            to {
                transform: translateX(400px);
                opacity: 0;
            }
        }

        .alert-toast.removing {
            animation: slideOutRight 0.3s ease forwards;
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Text colors */
        .text-success { color: var(--success); }
        .text-danger { color: var(--danger); }
        .text-warning { color: var(--warning); }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .fade-in {
            animation: fadeIn 0.3s ease;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.open {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
            }
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .user-name {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-icon">🌱</div>
                <div class="logo-text">Farm<span>Vision</span></div>
            </div>
        </div>
        <ul class="sidebar-menu">
            <!-- DASHBOARD -->
            <li class="{{ app.request.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                <a href="{{ path('admin_dashboard') }}"><i class="fas fa-chart-line"></i> Dashboard</a>
            </li>
            
            <!-- SECTION ÉQUIPEMENTS & MAINTENANCES -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">🚜 Parc matériel</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_equipement' ? 'active' : '' }}">
                <a href="{{ path('admin_equipement_index') }}"><i class="fas fa-tractor"></i> Équipements</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_maintenance' ? 'active' : '' }}">
                <a href="{{ path('admin_maintenance_index') }}"><i class="fas fa-wrench"></i> Maintenances</a>
            </li>
            
            <!-- SECTION CULTURES & PARCELLES -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">🌾 Agriculture</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_culture' ? 'active' : '' }}">
                <a href="{{ path('admin_culture_index') }}"><i class="fas fa-seedling"></i> Cultures</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_parcelle' ? 'active' : '' }}">
                <a href="{{ path('admin_parcelle_index') }}"><i class="fas fa-map-marked-alt"></i> Parcelles</a>
            </li>
            
            <!-- SECTION FINANCES -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">💰 Finances</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_depense' ? 'active' : '' }}">
                <a href="{{ path('admin_depense_index') }}"><i class="fas fa-money-bill-wave"></i> Dépenses</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_revenu' ? 'active' : '' }}">
                <a href="{{ path('admin_revenu_index') }}"><i class="fas fa-chart-line"></i> Revenus</a>
            </li>
            
            <!-- SECTION GESTION DES STOCKS & MARKETPLACE -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">📦 Commercial</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_stock' ? 'active' : '' }}">
                <a href="{{ path('admin_stock_index') }}"><i class="fas fa-boxes"></i> Stocks</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_marketplace' ? 'active' : '' }}">
                <a href="{{ path('admin_marketplace_index') }}"><i class="fas fa-store"></i> Marketplace</a>
            </li>
            
            <!-- SECTION OUTILS INTELLIGENTS -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">🤖 Outils IA</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_voice_chat' ? 'active' : '' }}">
                <a href="{{ path('admin_voice_chat') }}"><i class="fas fa-microphone"></i> Assistant Vocal</a>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_carbone' ? 'active' : '' }}">
                <a href="{{ path('admin_carbone_index') }}"><i class="fas fa-leaf"></i> Empreinte Carbone</a>
            </li>
            
            <!-- SECTION UTILISATEURS -->
            <li style="margin-top: 1rem; margin-bottom: 0.5rem;">
                <span style="padding: 0.5rem 1rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--gray); display: block;">👥 Administration</span>
            </li>
            <li class="{{ app.request.get('_route') starts with 'admin_user' ? 'active' : '' }}">
                <a href="{{ path('admin_user_index') }}"><i class="fas fa-users"></i> Utilisateurs</a>
            </li>
        </ul>
    </div>

    <div class="main-content">
        <div class="top-bar">
            <h1 class="page-title">{% block page_title %}Dashboard{% endblock %}</h1>
            
            <div style="display: flex; align-items: center; gap: 1rem;">
                <!-- Alertes notification bell -->
                <div class="alert-bell" id="alertBell">
                    <i class="fas fa-bell"></i>
                    <span class="alert-badge" id="alertBadge" style="display: none;">0</span>
                    
                    <div class="alert-dropdown">
                        <div class="alert-header">
                            <h3>🔔 Notifications</h3>
                            <button onclick="markAllRead()" style="background: none; border: none; color: var(--primary); cursor: pointer; font-size: 0.8rem;">
                                Tout marquer lu
                            </button>
                        </div>
                        <div class="alert-list" id="alertList">
                            <div class="alert-empty">
                                <i class="fas fa-check-circle" style="font-size: 2rem; color: var(--success); margin-bottom: 0.5rem;"></i>
                                <p>Aucune alerte</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Menu utilisateur déroulant -->
                <div class="user-menu" id="userMenu">
                    <div class="user-info">
                        <span class="user-name">{{ app.user.prenom }} {{ app.user.nom }}</span>
                        <div class="user-avatar">{{ app.user.prenom|first }}{{ app.user.nom|first }}</div>
                        <span class="dropdown-arrow">▼</span>
                    </div>
                    
                    <div class="user-dropdown">
                        <div class="dropdown-header">
                            <div class="name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                            <div class="email">{{ app.user.email }}</div>
                        </div>
                        
                        <a href="{{ path('profile_show') }}" class="dropdown-item">
                            <i class="fas fa-user"></i> Mon profil
                        </a>
                        
                        <a href="{{ path('profile_edit') }}" class="dropdown-item">
                            <i class="fas fa-cog"></i> Paramètres
                        </a>
                        
                        <div class="theme-switch">
                            <span><i class="fas fa-moon"></i> Thème</span>
                            <div class="theme-buttons">
                                <button onclick="setTheme('light')" class="theme-btn">☀️</button>
                                <button onclick="setTheme('dark')" class="theme-btn">🌙</button>
                            </div>
                        </div>
                        
                        <div class="dropdown-divider"></div>
                        
                        <a href="{{ path('app_logout') }}" class="dropdown-item logout">
                            <i class="fas fa-sign-out-alt"></i> Déconnexion
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="content">
            <!-- Flash messages -->
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-message flash-{{ label }}">
                        {% if label == 'success' %}✅ {% elseif label == 'error' %}❌ {% elseif label == 'warning' %}⚠️ {% endif %}
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
            
            <!-- Alert Toast Container -->
            <div class="alert-toast-container" id="alertToastContainer"></div>
            
            {% block body %}{% endblock %}
        </div>
    </div>

    <script>
        // Toggle dropdown menu
        const userMenu = document.getElementById('userMenu');
        userMenu.addEventListener('click', function(e) {
            e.stopPropagation();
            this.classList.toggle('active');
            // Fermer les alertes si ouvertes
            document.getElementById('alertBell').classList.remove('active');
        });
        
        // Toggle alert bell
        const alertBell = document.getElementById('alertBell');
        alertBell.addEventListener('click', function(e) {
            e.stopPropagation();
            this.classList.toggle('active');
            // Fermer le menu utilisateur si ouvert
            userMenu.classList.remove('active');
        });
        
        // Fermer les dropdowns en cliquant ailleurs
        document.addEventListener('click', function() {
            userMenu.classList.remove('active');
            alertBell.classList.remove('active');
        });
        
        // Charger les alertes
        function loadAlertes() {
            fetch('/admin/alertes/notifications')
                .then(response => response.json())
                .then(data => {
                    const alertList = document.getElementById('alertList');
                    const alertBadge = document.getElementById('alertBadge');
                    
                    if (data.non_lues > 0) {
                        alertBadge.textContent = data.non_lues;
                        alertBadge.style.display = 'block';
                    } else {
                        alertBadge.style.display = 'none';
                    }
                    
                    if (data.alertes.length === 0) {
                        alertList.innerHTML = `
                            <div class="alert-empty">
                                <i class="fas fa-check-circle" style="font-size: 2rem; color: var(--success); margin-bottom: 0.5rem;"></i>
                                <p>Aucune alerte</p>
                            </div>
                        `;
                        return;
                    }
                    
                    alertList.innerHTML = data.alertes.map(alerte => {
                        const typeColors = {
                            'URGENT': '#dc2626',
                            'WARNING': '#f59e0b',
                            'INFO': '#10b981'
                        };
                        const color = typeColors[alerte.type] || '#10b981';
                        const unreadClass = alerte.read ? '' : 'unread';
                        
                        return `
                            <div class="alert-item ${unreadClass}" onclick="handleAlertClick('${alerte.id}', '${alerte.lien}')">
                                <div class="alert-item-header">
                                    <span style="font-size: 1.2rem;">${alerte.icone}</span>
                                    <span class="alert-item-title">${alerte.titre}</span>
                                    <span style="margin-left: auto; padding: 0.15rem 0.5rem; background: ${color}; color: white; font-size: 0.65rem; border-radius: 999px; font-weight: 600;">${alerte.type}</span>
                                </div>
                                <div class="alert-item-message">${alerte.message}</div>
                                <div class="alert-item-time">${formatDate(alerte.date)}</div>
                            </div>
                        `;
                    }).join('');
                })
                .catch(error => console.error('Erreur chargement alertes:', error));
        }
        
        // Afficher les alertes en toast
        function showAlertToasts() {
            fetch('/admin/alertes/notifications')
                .then(response => response.json())
                .then(data => {
                    const container = document.getElementById('alertToastContainer');
                    
                    // Afficher seulement les alertes urgentes non lues
                    const urgentesNonLues = data.alertes.filter(a => a.type === 'URGENT' && !a.read);
                    
                    urgentesNonLues.slice(0, 4).forEach((alerte, index) => {
                        setTimeout(() => {
                            showToast(alerte);
                        }, index * 500); // Décalage de 500ms entre chaque toast
                    });
                })
                .catch(error => console.error('Erreur chargement toasts:', error));
        }
        
        function showToast(alerte) {
            const container = document.getElementById('alertToastContainer');
            
            const typeClass = alerte.type === 'URGENT' ? '' : (alerte.type === 'WARNING' ? 'warning' : 'info');
            
            const toast = document.createElement('div');
            toast.className = `alert-toast ${typeClass}`;
            toast.innerHTML = `
                <div class="alert-toast-icon">⚠️</div>
                <div class="alert-toast-content">
                    <div class="alert-toast-title">
                        ${alerte.icone} ${alerte.titre}
                    </div>
                    <div class="alert-toast-message">${alerte.message}</div>
                </div>
                <button class="alert-toast-close" onclick="closeToast(this)">×</button>
            `;
            
            // Clic sur le toast pour marquer comme lu et rediriger
            toast.addEventListener('click', (e) => {
                if (!e.target.classList.contains('alert-toast-close')) {
                    handleAlertClick(alerte.id, alerte.lien);
                    closeToast(toast.querySelector('.alert-toast-close'));
                }
            });
            
            container.appendChild(toast);
            
            // Auto-fermeture après 10 secondes
            setTimeout(() => {
                if (toast.parentElement) {
                    closeToast(toast.querySelector('.alert-toast-close'));
                }
            }, 10000);
        }
        
        function closeToast(button) {
            const toast = button.closest('.alert-toast');
            toast.classList.add('removing');
            setTimeout(() => {
                toast.remove();
            }, 300);
        }
        
        function handleAlertClick(alertId, lien) {
            // Marquer comme lu
            fetch('/admin/alertes/mark-read', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({id: alertId})
            }).then(() => {
                loadAlertes();
                if (lien && lien !== '#') {
                    window.location.href = lien;
                }
            });
        }
        
        function markAllRead() {
            fetch('/admin/alertes/mark-all-read', {
                method: 'POST'
            }).then(() => {
                loadAlertes();
            });
        }
        
        function formatDate(dateStr) {
            const date = new Date(dateStr);
            const now = new Date();
            const diff = Math.floor((now - date) / 1000);
            
            if (diff < 60) return 'À l\'instant';
            if (diff < 3600) return Math.floor(diff / 60) + ' min';
            if (diff < 86400) return Math.floor(diff / 3600) + ' h';
            return Math.floor(diff / 86400) + ' j';
        }
        
        // Charger les alertes au démarrage
        loadAlertes();
        
        // Afficher les toasts au démarrage
        showAlertToasts();
        
        // Recharger toutes les 30 secondes
        setInterval(loadAlertes, 30000);
        
        // Thème Dark/Light
        function setTheme(theme) {
            if (theme === 'dark') {
                document.body.classList.add('dark-theme');
                localStorage.setItem('theme', 'dark');
            } else {
                document.body.classList.remove('dark-theme');
                localStorage.setItem('theme', 'light');
            }
        }
        
        // Charger le thème sauvegardé
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
            document.body.classList.add('dark-theme');
        }
        
        // Supprimer les messages flash après 5 secondes
        setTimeout(() => {
            document.querySelectorAll('.flash-message').forEach(msg => {
                msg.style.opacity = '0';
                msg.style.transform = 'translateX(100%)';
                setTimeout(() => msg.remove(), 300);
            });
        }, 5000);
        
        // Active link detection
        document.querySelectorAll('.sidebar-menu li a').forEach(link => {
            const currentPath = window.location.pathname;
            const linkPath = link.getAttribute('href');
            if (linkPath && currentPath === linkPath) {
                link.closest('li').classList.add('active');
            }
        });
    </script>
</body>
</html>