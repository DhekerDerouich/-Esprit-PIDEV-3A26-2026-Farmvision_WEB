{% extends 'admin/base.html.twig' %}

{% block page_title %}Gestion des Dépenses - Admin{% endblock %}

{% block body %}
<div class="fade-in">
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">💰</div>
            <div class="stat-value">{{ totalDepenses|number_format(2) }} DT</div>
            <div class="stat-label">Total des dépenses</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">📋</div>
            <div class="stat-value">{{ depenses.getTotalItemCount }}</div>
            <div class="stat-label">Nombre total</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>🔍 Filtres</h3>
        </div>
        <form method="get" class="search-bar">
            <input type="text" name="search" class="search-input" value="{{ search }}" placeholder="Rechercher...">

            <select name="responsable" class="search-input">
                <option value="all">Tous les responsables</option>
                {% for responsable in responsables %}
                    <option value="{{ responsable.id }}" {% if selectedResponsable == responsable.id %}selected{% endif %}>
                        {{ responsable.prenom }} {{ responsable.nom }} ({{ responsable.email }})
                    </option>
                {% endfor %}
            </select>

            <select name="type" class="search-input">
                <option value="all">Tous les types</option>
                {% for type in typeOptions %}
                    <option value="{{ type }}" {% if selectedType == type %}selected{% endif %}>{{ type }}</option>
                {% endfor %}
            </select>

            <input type="date" name="start_date" class="search-input" value="{{ startDate }}" placeholder="Date début">
            <input type="date" name="end_date" class="search-input" value="{{ endDate }}" placeholder="Date fin">

            <button type="submit" class="btn btn-primary">🔍 Filtrer</button>
            <a href="{{ path('admin_depense_index') }}" class="btn btn-outline">🔄 Réinitialiser</a>
        </form>
    </div>

    <div class="card">
        <h3>📋 Liste des dépenses</h3>

        {% if depenses|length > 0 %}
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Responsable</th>
                    <th>Type</th>
                    <th>Montant</th>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for depense in depenses %}
                <tr>
                    <td style="vertical-align: middle;">#{{ depense.id }}</td>
                    <td>
                        {% if responsablesMap[depense.userId] is defined %}
                            <strong>{{ responsablesMap[depense.userId].prenom }} {{ responsablesMap[depense.userId].nom }}</strong><br>
                            <small style="color: var(--gray);">{{ responsablesMap[depense.userId].email }}</small>
                        {% else %}
                            <span class="badge badge-warning">Utilisateur inconnu</span>
                            <small>(ID: {{ depense.userId }})</small>
                        {% endif %}
                    </td>
                    <td><span class="badge badge-warning">{{ depense.typeDepense }}</span></td>
                    <td class="text-danger" style="font-weight: 600;">{{ depense.montant|number_format(2) }} DT</td>
                    <td>{{ depense.dateDepense|date('d/m/Y') }}</td>
                    <td>{{ depense.description|slice(0, 50) }}{% if depense.description|length > 50 %}...{% endif %}</td>
                    <td style="white-space: nowrap;">
                        <a href="{{ path('admin_depense_show', {'id': depense.id}) }}" class="btn btn-sm btn-outline" style="margin-right: 5px;">👁️</a>
                        <form method="post" action="{{ path('admin_depense_delete', {'id': depense.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette dépense ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ depense.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline" style="color: var(--red);">🗑️</button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div style="text-align: center; padding: 3rem; color: var(--gray);">
            <p>Aucune dépense trouvée.</p>
        </div>
        {% endif %}

        <div class="pagination-container" style="margin-top: 2rem;">
            {{ knp_pagination_render(depenses) }}
        </div>
    </div>
</div>
{% endblock %}