{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier la parcelle{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    #map { height: 400px; border-radius: var(--radius); margin-bottom: 1rem; }
    .coord-display { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
    .coord-box { background: var(--light); padding: 0.75rem; border-radius: var(--radius); border: 1px solid var(--gray-lighter); }
    .coord-box label { font-size: 0.75rem; color: var(--gray); display: block; margin-bottom: 0.25rem; }
    .coord-box span { font-weight: 600; color: var(--dark); }
</style>

<div style="margin-bottom: 1.5rem;">
    <a href="{{ path('admin_parcelle_index') }}" class="btn btn-outline">
        <i class="fas fa-arrow-left"></i> Retour
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h3>✏️ Modifier la parcelle</h3>
    </div>

    {% if errors is not empty %}
    <div style="padding: 1rem; background: #fee2e2; border: 1px solid var(--danger); border-radius: var(--radius); margin-bottom: 1.5rem;">
        <p style="color: var(--danger); font-weight: 600; margin-bottom: 0.5rem;">⚠️ Erreurs de validation :</p>
        <ul style="margin: 0; padding-left: 1.5rem; color: var(--danger);">
            {% for error in errors %}
                <li>{{ error }}</li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    <form method="post">
        <input type="hidden" name="latitude" id="lat" value="{{ parcelle.latitude ?? '' }}">
        <input type="hidden" name="longitude" id="lng" value="{{ parcelle.longitude ?? '' }}">

        <div class="form-group">
            <label>Localisation *</label>
            <input type="text" name="localisation" id="localisationInput" class="form-control" value="{{ parcelle.localisation }}" required>
        </div>

        <div class="form-group">
            <label>Surface (ha) *</label>
            <input type="number" name="surface" class="form-control" value="{{ parcelle.surface }}" min="0.01" step="0.01" required>
        </div>

        <div class="form-group">
            <label>📍 Position sur la carte</label>
            <div id="map"></div>
            <div class="coord-display">
                <div class="coord-box">
                    <label>Latitude</label>
                    <span id="displayLat">{{ parcelle.latitude ? parcelle.latitude|number_format(5) : '—' }}</span>
                </div>
                <div class="coord-box">
                    <label>Longitude</label>
                    <span id="displayLng">{{ parcelle.longitude ? parcelle.longitude|number_format(5) : '—' }}</span>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Enregistrer les modifications
        </button>
    </form>
</div>

<script>
    var initLat = {{ parcelle.latitude ?? 36.8065 }};
    var initLng = {{ parcelle.longitude ?? 10.1815 }};
    var hasCoords = {{ (parcelle.latitude is not null) ? 'true' : 'false' }};

    var map = L.map('map').setView([initLat, initLng], hasCoords ? 13 : 6);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap'
    }).addTo(map);

    var marker = null;

    function placeMarker(lat, lng) {
        if (marker) map.removeLayer(marker);
        marker = L.marker([lat, lng], { draggable: true }).addTo(map);
        updateCoords(lat, lng);
        marker.on('dragend', function(e) {
            var pos = e.target.getLatLng();
            updateCoords(pos.lat, pos.lng);
            reverseGeocode(pos.lat, pos.lng);
        });
    }

    function updateCoords(lat, lng) {
        document.getElementById('lat').value = lat.toFixed(6);
        document.getElementById('lng').value = lng.toFixed(6);
        document.getElementById('displayLat').textContent = lat.toFixed(5);
        document.getElementById('displayLng').textContent = lng.toFixed(5);
    }

    function reverseGeocode(lat, lng) {
        fetch('https://nominatim.openstreetmap.org/reverse?format=json&lat=' + lat + '&lon=' + lng)
            .then(r => r.json())
            .then(data => {
                if (data && data.address) {
                    var short = data.address.city || data.address.town || data.address.village || data.address.county || '';
                    var input = document.getElementById('localisationInput');
                    if (short && confirm('Remplacer la localisation actuelle par "' + short + '" ?')) {
                        input.value = short;
                    }
                }
            }).catch(() => {});
    }

    if (hasCoords) placeMarker(initLat, initLng);

    map.on('click', function(e) {
        placeMarker(e.latlng.lat, e.latlng.lng);
        reverseGeocode(e.latlng.lat, e.latlng.lng);
    });
</script>
{% endblock %}
