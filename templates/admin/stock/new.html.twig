{% extends 'admin/base.html.twig' %}

{% block page_title %}Ajouter un produit{% endblock %}

{% block body %}
<div style="margin-bottom: 2rem;">
    <a href="{{ path('admin_stock_index') }}" class="btn" style="background: var(--bg-panel);">← Retour</a>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h1 style="font-size: 1.5rem; margin-bottom: 1.5rem;">➕ Ajouter un produit au stock</h1>
    
    <form method="post">
        <div class="form-group">
            <label>Nom du produit *</label>
            <input type="text" name="nom_produit" class="form-control" required>
        </div>
        
        <div class="form-group">
            <label>Type de produit</label>
            <select name="type_produit" class="form-control">
                <option value="">Sélectionner</option>
                <option value="Légumes">🥕 Légumes</option>
                <option value="Fruits">🍎 Fruits</option>
                <option value="Céréales">🌾 Céréales</option>
                <option value="Engrais">🧪 Engrais</option>
                <option value="Semences">🌱 Semences</option>
                <option value="Outils">🔧 Outils</option>
            </select>
        </div>
        
        <div class="form-group">
            <label>Quantité *</label>
            <input type="number" step="0.01" name="quantite" class="form-control" required>
        </div>
        
        <div class="form-group">
            <label>Unité</label>
            <select name="unite" class="form-control">
                <option value="kg">kg</option>
                <option value="g">g</option>
                <option value="L">L</option>
                <option value="mL">mL</option>
                <option value="unité">unité</option>
                <option value="sac">sac</option>
                <option value="botte">botte</option>
            </select>
        </div>
        
        <div class="form-group">
            <label>Date d'expiration</label>
            <input type="date" name="date_expiration" class="form-control">
            <small style="color: var(--text-muted);">Optionnel</small>
        </div>
        
        <div class="form-group">
            <label>Statut</label>
            <select name="statut" class="form-control">
                <option value="Disponible">Disponible</option>
                <option value="Épuisé">Épuisé</option>
            </select>
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
            <a href="{{ path('admin_stock_index') }}" class="btn" style="background: var(--bg-panel);">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}