{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier l'offre{% endblock %}

{% block body %}
<div style="margin-bottom: 2rem;">
    <a href="{{ path('admin_marketplace_index') }}" class="btn" style="background: var(--bg-panel);">← Retour</a>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h1 style="font-size: 1.5rem; margin-bottom: 1.5rem;">✏️ Modifier l'offre</h1>
    
    <form method="post">
        <div class="form-group">
            <label>Produit</label>
            <input type="text" value="{{ marketplace.stock.nomProduit }}" class="form-control" disabled>
        </div>
        
        <div class="form-group">
            <label>Prix unitaire (DT) *</label>
            <input type="number" step="0.01" name="prix_unitaire" value="{{ marketplace.prixUnitaire }}" class="form-control" required>
        </div>
        
        <div class="form-group">
            <label>Quantité en vente *</label>
            <input type="number" step="0.01" name="quantite_en_vente" value="{{ marketplace.quantiteEnVente }}" class="form-control" required>
        </div>
        
        <div class="form-group">
            <label>Description</label>
            <textarea name="description" class="form-control" rows="4">{{ marketplace.description }}</textarea>
        </div>
        
        <div class="form-group">
            <label>Statut</label>
            <select name="statut" class="form-control">
                <option value="En vente" {% if marketplace.statut == 'En vente' %}selected{% endif %}>En vente</option>
                <option value="Vendu" {% if marketplace.statut == 'Vendu' %}selected{% endif %}>Vendu</option>
            </select>
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
            <a href="{{ path('admin_marketplace_index') }}" class="btn" style="background: var(--bg-panel);">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}