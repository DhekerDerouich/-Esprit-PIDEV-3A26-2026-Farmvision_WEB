{% extends 'admin/base.html.twig' %}

{% block page_title %}Mettre en vente{% endblock %}

{% block body %}
<div style="margin-bottom: 2rem;">
    <a href="{{ path('admin_marketplace_index') }}" class="btn" style="background: var(--bg-panel);">← Retour</a>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h1 style="font-size: 1.5rem; margin-bottom: 1.5rem;">💰 Mettre un produit en vente</h1>
    
    <form method="post">
        <div class="form-group">
            <label>Produit *</label>
            <select name="stock_id" class="form-control" required>
                <option value="">Sélectionner un produit</option>
                {% for stock in stocks %}
                    <option value="{{ stock.id }}">{{ stock.nomProduit }} - {{ stock.quantite }} {{ stock.unite }} disponible</option>
                {% endfor %}
            </select>
        </div>
        
        <div class="form-group">
            <label>Prix unitaire (DT) *</label>
            <input type="number" step="0.01" name="prix_unitaire" class="form-control" required>
        </div>
        
        <div class="form-group">
            <label>Quantité en vente *</label>
            <input type="number" step="0.01" name="quantite_en_vente" class="form-control" required>
            <small style="color: var(--text-muted);">Maximum disponible: à vérifier dans le stock</small>
        </div>
        
        <div class="form-group">
            <label>Description</label>
            <textarea name="description" class="form-control" rows="4" placeholder="Description du produit, qualités, origine..."></textarea>
        </div>
        
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">💰 Mettre en vente</button>
            <a href="{{ path('admin_marketplace_index') }}" class="btn" style="background: var(--bg-panel);">Annuler</a>
        </div>
    </form>
</div>
{% endblock %}