{% extends 'front/base.html.twig' %}

{% block body %}
<style>
.public-profile {
    max-width: 600px;
    margin: 2rem auto;
    padding: 0 1rem;
}

.profile-card {
    background: white;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    overflow: hidden;
}

.profile-header {
    background: linear-gradient(135deg, #1a3a2a 0%, #2d6a4f 100%);
    padding: 3rem 2rem;
    text-align: center;
    color: white;
}

.profile-avatar {
    width: 120px;
    height: 120px;
    background: white;
    border-radius: 50%;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: #2d6a4f;
    border: 4px solid white;
    box-shadow: 0 5px 20px rgba(0,0,0,0.2);
}

.profile-name {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.profile-role {
    opacity: 0.9;
    font-size: 1rem;
}

.profile-body {
    padding: 2rem;
}

.info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 12px;
    margin-bottom: 1rem;
}

.info-icon {
    width: 40px;
    height: 40px;
    background: #2d6a4f;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
}

.info-content {
    flex: 1;
}

.info-label {
    font-size: 0.75rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.info-value {
    font-weight: 600;
    color: #1a3a2a;
}

.badge-role {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 1rem;
}

.badge-admin { background: #fee2e2; color: #991b1b; }
.badge-responsable { background: #fed7aa; color: #92400e; }
.badge-agriculteur { background: #d1fae5; color: #065f46; }

.footer-brand {
    text-align: center;
    padding: 2rem;
    color: #666;
}

.footer-brand a {
    color: #2d6a4f;
    text-decoration: none;
    font-weight: 600;
}
</style>

<div class="public-profile">
    <div class="profile-card">
        <div class="profile-header">
            {{ include('profile/_avatar.html.twig', {
                user: user,
                wrapperClass: 'profile-avatar',
                fallbackText: user.prenom|first ~ user.nom|first,
                alt: 'Photo de profil'
            }) }}
            <h1 class="profile-name">{{ user.prenom }} {{ user.nom }}</h1>
            <p class="profile-role">
                {% if user.typeRole == 'ADMINISTRATEUR' %}
                    👑 Administrateur
                {% elseif user.typeRole == 'RESPONSABLE_EXPLOITATION' %}
                    📋 Responsable d'exploitation
                {% else %}
                    🌾 Agriculteur
                {% endif %}
            </p>
            <span class="badge-role {{ user.typeRole == 'ADMINISTRATEUR' ? 'badge-admin' : (user.typeRole == 'RESPONSABLE_EXPLOITATION' ? 'badge-responsable' : 'badge-agriculteur') }}">
                FarmVision
            </span>
        </div>

        <div class="profile-body">
            <div class="info-item">
                <div class="info-icon">📧</div>
                <div class="info-content">
                    <div class="info-label">Email</div>
                    <div class="info-value">{{ user.email }}</div>
                </div>
            </div>

            {% if user.telephone %}
            <div class="info-item">
                <div class="info-icon">📞</div>
                <div class="info-content">
                    <div class="info-label">Téléphone</div>
                    <div class="info-value">{{ user.telephone }}</div>
                </div>
            </div>
            {% endif %}

            {% if user.adresse %}
            <div class="info-item">
                <div class="info-icon">📍</div>
                <div class="info-content">
                    <div class="info-label">Adresse</div>
                    <div class="info-value">{{ user.adresse }}</div>
                </div>
            </div>
            {% endif %}

            <div class="info-item">
                <div class="info-icon">📅</div>
                <div class="info-content">
                    <div class="info-label">Membre depuis</div>
                    <div class="info-value">{{ user.dateCreation ? user.dateCreation|date('d/m/Y') : '-' }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="footer-brand">
        <p>🎉 Ce profil est hébergé sur <a href="{{ path('app_home') }}">FarmVision</a></p>
        <p style="font-size: 0.8rem; margin-top: 0.5rem;">Plateforme de gestion agricole intelligente</p>
    </div>
</div>
{% endblock %}
