{% extends 'front/base.html.twig' %}

{% block body %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .test-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 2rem;
    }
    .test-section {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .test-section h2 {
        color: var(--green-deep);
        margin-bottom: 1rem;
    }
    #test-map {
        height: 400px;
        border-radius: 8px;
        margin-top: 1rem;
    }
    .result-box {
        background: #f5f5f5;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1rem;
        font-family: monospace;
        font-size: 0.9rem;
        white-space: pre-wrap;
        word-wrap: break-word;
    }
    .success { color: #2d6a4f; }
    .error { color: #e74c3c; }
    .btn-test {
        background: var(--green-mid);
        color: white;
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        margin-right: 1rem;
    }
    .btn-test:hover {
        background: var(--green-deep);
    }
</style>

<div class="test-container">
    <h1>🔧 Test des APIs - FarmVision</h1>
    
    <!-- Leaflet Map Test -->
    <div class="test-section">
        <h2>🗺️ Test Leaflet Map</h2>
        <p>Test de l'initialisation de la carte Leaflet avec OpenStreetMap</p>
        <button class="btn-test" onclick="testMap()">Initialiser la carte</button>
        <div id="test-map"></div>
        <div id="map-result" class="result-box" style="display:none;"></div>
    </div>

    <!-- Weather API Test -->
    <div class="test-section">
        <h2>🌤️ Test OpenWeather API</h2>
        <p>Test de l'API météo avec des coordonnées de test (Paris: 48.8566, 2.3522)</p>
        <button class="btn-test" onclick="testWeatherDirect()">Test API Direct</button>
        <button class="btn-test" onclick="testWeatherSymfony()">Test via Symfony</button>
        <div id="weather-result" class="result-box" style="display:none;"></div>
    </div>

    <!-- Parcelle Weather Test -->
    <div class="test-section">
        <h2>📍 Test Météo Parcelle</h2>
        <p>Test de l'endpoint météo pour une parcelle spécifique</p>
        <input type="number" id="parcelle-id" placeholder="ID Parcelle" style="padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px; margin-right: 1rem;">
        <button class="btn-test" onclick="testParcelleWeather()">Tester</button>
        <div id="parcelle-result" class="result-box" style="display:none;"></div>
    </div>

    <!-- Browser Console Test -->
    <div class="test-section">
        <h2>🖥️ Informations Navigateur</h2>
        <div id="browser-info" class="result-box"></div>
    </div>
</div>

<script>
// Display browser info
document.getElementById('browser-info').textContent = 
    'User Agent: ' + navigator.userAgent + '\n' +
    'Leaflet loaded: ' + (typeof L !== 'undefined' ? 'YES ✓' : 'NO ✗') + '\n' +
    'Fetch API: ' + (typeof fetch !== 'undefined' ? 'YES ✓' : 'NO ✗');

// Test Leaflet Map
function testMap() {
    const resultDiv = document.getElementById('map-result');
    resultDiv.style.display = 'block';
    
    try {
        const map = L.map('test-map').setView([48.8566, 2.3522], 13);
        
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);
        
        L.marker([48.8566, 2.3522]).addTo(map)
            .bindPopup('Paris - Test Location')
            .openPopup();
        
        setTimeout(() => map.invalidateSize(), 100);
        
        resultDiv.innerHTML = '<span class="success">✓ Carte initialisée avec succès!</span>';
    } catch (error) {
        resultDiv.innerHTML = '<span class="error">✗ Erreur: ' + error.message + '</span>';
    }
}

// Test Weather API Direct
async function testWeatherDirect() {
    const resultDiv = document.getElementById('weather-result');
    resultDiv.style.display = 'block';
    resultDiv.textContent = '⏳ Test en cours...';
    
    const apiKey = '10f4b8f78ff1854d402feade0f123605';
    const url = `https://api.openweathermap.org/data/2.5/weather?lat=48.8566&lon=2.3522&appid=${apiKey}&units=metric&lang=fr`;
    
    try {
        const response = await fetch(url);
        const data = await response.json();
        
        if (response.ok) {
            resultDiv.innerHTML = '<span class="success">✓ API OpenWeather fonctionne!</span>\n\n' +
                JSON.stringify(data, null, 2);
        } else {
            resultDiv.innerHTML = '<span class="error">✗ Erreur API: ' + data.message + '</span>\n\n' +
                JSON.stringify(data, null, 2);
        }
    } catch (error) {
        resultDiv.innerHTML = '<span class="error">✗ Erreur réseau: ' + error.message + '</span>';
    }
}

// Test Weather via Symfony (create a test endpoint)
async function testWeatherSymfony() {
    const resultDiv = document.getElementById('weather-result');
    resultDiv.style.display = 'block';
    resultDiv.textContent = '⏳ Test via Symfony...';
    
    try {
        const response = await fetch('/test/weather');
        const data = await response.json();
        
        if (response.ok) {
            resultDiv.innerHTML = '<span class="success">✓ Service Symfony fonctionne!</span>\n\n' +
                JSON.stringify(data, null, 2);
        } else {
            resultDiv.innerHTML = '<span class="error">✗ Erreur: ' + (data.error || 'Erreur inconnue') + '</span>\n\n' +
                JSON.stringify(data, null, 2);
        }
    } catch (error) {
        resultDiv.innerHTML = '<span class="error">✗ Erreur: ' + error.message + '</span>';
    }
}

// Test Parcelle Weather
async function testParcelleWeather() {
    const parcelleId = document.getElementById('parcelle-id').value;
    const resultDiv = document.getElementById('parcelle-result');
    resultDiv.style.display = 'block';
    
    if (!parcelleId) {
        resultDiv.innerHTML = '<span class="error">✗ Veuillez entrer un ID de parcelle</span>';
        return;
    }
    
    resultDiv.textContent = '⏳ Chargement...';
    
    try {
        const response = await fetch(`/parcelle/${parcelleId}/weather`);
        const data = await response.json();
        
        if (response.ok) {
            resultDiv.innerHTML = '<span class="success">✓ Données météo récupérées!</span>\n\n' +
                JSON.stringify(data, null, 2);
        } else {
            resultDiv.innerHTML = '<span class="error">✗ Erreur: ' + (data.error || 'Erreur inconnue') + '</span>\n\n' +
                'Status: ' + response.status + '\n' +
                JSON.stringify(data, null, 2);
        }
    } catch (error) {
        resultDiv.innerHTML = '<span class="error">✗ Erreur réseau: ' + error.message + '</span>';
    }
}
</script>
{% endblock %}
