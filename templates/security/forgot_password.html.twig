{% extends 'front/base.html.twig' %}

{% block body %}
<div class="container" style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 4rem 0;">
    <div class="card" style="max-width: 460px; width: 100%; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem;">✉️</div>
            <h1 style="font-size: 1.8rem; margin-bottom: 0.5rem;">Mot de passe oublié</h1>
            <p style="color: #667085;">Saisissez votre email pour recevoir un lien de réinitialisation.</p>
        </div>

        <form method="post" novalidate>
            <div style="margin-bottom: 1rem;">
                <input type="email" name="email" value="{{ email }}" placeholder="Votre email" class="form-control {% if errors.email is defined %}error{% endif %}" style="width: 100%; padding: 0.75rem;" required>
                {% if errors.email is defined %}
                    <span style="color: #e05c5c; font-size: 0.75rem; margin-top: 0.35rem; display: block;">{{ errors.email }}</span>
                {% endif %}
            </div>

            <button type="submit" class="btn-primary" style="width: 100%; padding: 0.75rem;">Envoyer le lien</button>

            <div style="text-align: center; margin-top: 1rem;">
                <a href="{{ path('app_login') }}" style="color: var(--green-mid);">Retour à la connexion</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
