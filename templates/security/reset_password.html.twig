{% extends 'front/base.html.twig' %}

{% block body %}
<div class="container" style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 4rem 0;">
    <div class="card" style="max-width: 460px; width: 100%; margin: 0 auto;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem;">🔐</div>
            <h1 style="font-size: 1.8rem; margin-bottom: 0.5rem;">Nouveau mot de passe</h1>
            <p style="color: #667085;">Choisissez un nouveau mot de passe sécurisé pour votre compte.</p>
        </div>

        <form method="post" novalidate>
            <div style="margin-bottom: 1rem;">
                <input type="password" name="password" placeholder="Nouveau mot de passe" class="form-control {% if errors.password is defined %}error{% endif %}" style="width: 100%; padding: 0.75rem;" required>
                {% if errors.password is defined %}
                    <span style="color: #e05c5c; font-size: 0.75rem; margin-top: 0.35rem; display: block;">{{ errors.password }}</span>
                {% endif %}
            </div>

            <div style="margin-bottom: 1rem;">
                <input type="password" name="password_confirm" placeholder="Confirmer le mot de passe" class="form-control {% if errors.password_confirm is defined %}error{% endif %}" style="width: 100%; padding: 0.75rem;" required>
                {% if errors.password_confirm is defined %}
                    <span style="color: #e05c5c; font-size: 0.75rem; margin-top: 0.35rem; display: block;">{{ errors.password_confirm }}</span>
                {% endif %}
            </div>

            <p style="font-size: 0.8rem; color: #667085; margin-bottom: 1rem;">Minimum 6 caractères avec une majuscule, une minuscule et un chiffre.</p>

            <button type="submit" class="btn-primary" style="width: 100%; padding: 0.75rem;">Mettre à jour le mot de passe</button>
        </form>
    </div>
</div>
{% endblock %}
