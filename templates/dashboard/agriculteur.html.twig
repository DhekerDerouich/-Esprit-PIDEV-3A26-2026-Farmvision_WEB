{% extends 'front/base.html.twig' %}

{% block body %}
<style>
    .dash-wrap { max-width: 1100px; margin: 0 auto; padding: 3rem 2rem; }

    .dash-hero {
        background: linear-gradient(135deg, var(--green-deep) 0%, var(--green-mid) 100%);
        border-radius: 20px;
        padding: 2rem 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        color: white;
    }
    .dash-hero-left h1 { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; margin-bottom: 0.25rem; }
    .dash-hero-left p { opacity: 0.8; font-size: 0.9rem; }
    .dash-hero-avatar {
        width: 56px; height: 56px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; font-weight: 700;
        border: 2px solid rgba(255,255,255,0.4);
    }

    .dash-section-title {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        margin-bottom: 1rem;
    }

    .dash-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-bottom: 2rem; }

    .dash-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e8f0eb;
        box-shadow: 0 2px 16px rgba(45,106,79,0.06);
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .dash-card:hover { transform: translateY(-3px); box-shadow: 0 10px 36px rgba(45,106,79,0.13); }

    .dash-card-header {
        padding: 1.25rem 1.25rem 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .dash-card-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }
    .icon-culture { background: #e8f5e9; }
    .icon-parcelle { background: #e3f2fd; }
    .icon-profile { background: #fef9ec; }

    .dash-card-header h3 { font-size: 1rem; font-weight: 700; color: var(--green-deep); margin: 0; }
    .dash-card-header p { font-size: 0.75rem; color: var(--text-muted); margin: 0.1rem 0 0; }

    .dash-divider { height: 1px; background: #f0f4f2; margin: 0 1.25rem; }
    .dash-card-body { padding: 1rem 1.25rem 1.25rem; }
    .dash-card-body .desc { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.5; }

    .dash-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }
    .dash-btn-primary {
        display: inline-flex; align-items: center; gap: 0.4rem;
        background: var(--green-mid); color: #fff;
        padding: 0.5rem 1rem; border-radius: 8px;
        text-decoration: none; font-size: 0.8rem; font-weight: 600;
        transition: all 0.2s;
    }
    .dash-btn-primary:hover { background: var(--green-deep); transform: translateY(-1px); }
    .dash-btn-outline {
        display: inline-flex; align-items: center; gap: 0.4rem;
        background: transparent; color: var(--green-mid);
        border: 1.5px solid var(--green-mid);
        padding: 0.5rem 1rem; border-radius: 8px;
        text-decoration: none; font-size: 0.8rem; font-weight: 600;
        transition: background 0.2s;
    }
    .dash-btn-outline:hover { background: var(--green-mist); }

    .dash-info-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e8f0eb;
        padding: 1.25rem 1.5rem;
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }
    .dash-info-icon { font-size: 1.5rem; flex-shrink: 0; }
    .dash-info-card h4 { font-size: 0.9rem; font-weight: 700; color: var(--green-deep); margin-bottom: 0.25rem; }
    .dash-info-card p { font-size: 0.8rem; color: var(--text-muted); margin: 0; }
</style>

<div class="dash-wrap">
    <div class="dash-hero">
        <div class="dash-hero-left">
            <h1>👨‍🌾 Mon espace agriculteur</h1>
            <p>Bienvenue, gérez vos ressources agricoles depuis votre tableau de bord</p>
        </div>
        <div style="text-align:right;">
            <div class="dash-hero-avatar">{{ app.user.prenom|first }}{{ app.user.nom|first }}</div>
            <div style="font-size:0.8rem; margin-top: 0.5rem;">{{ app.user.prenom }} {{ app.user.nom }}</div>
        </div>
    </div>

    <div class="dash-section-title">📋 Mes modules</div>

    <div class="dash-grid">
        <!-- Cultures -->
        <div class="dash-card">
            <div class="dash-card-header">
                <div class="dash-card-icon icon-culture">🌾</div>
                <div>
                    <h3>Cultures</h3>
                    <p>Gestion des cultures</p>
                </div>
            </div>
            <div class="dash-divider"></div>
            <div class="dash-card-body">
                <p class="desc">Gérez vos cultures : ajout, modification, suivi des récoltes.</p>
                <div class="dash-actions">
                    <a href="{{ path('front_culture_index') }}" class="dash-btn-primary">Voir →</a>
                    <a href="{{ path('front_culture_new') }}" class="dash-btn-outline">+ Ajouter</a>
                </div>
            </div>
        </div>

        <!-- Parcelles -->
        <div class="dash-card">
            <div class="dash-card-header">
                <div class="dash-card-icon icon-parcelle">🗺️</div>
                <div>
                    <h3>Parcelles</h3>
                    <p>Gestion des terres</p>
                </div>
            </div>
            <div class="dash-divider"></div>
            <div class="dash-card-body">
                <p class="desc">Gérez vos parcelles agricoles et leur localisation.</p>
                <div class="dash-actions">
                    <a href="{{ path('front_parcelle_index') }}" class="dash-btn-primary">Voir →</a>
                    <a href="{{ path('front_parcelle_new') }}" class="dash-btn-outline">+ Ajouter</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Mon profil -->
    <div class="dash-info-card">
        <div class="dash-info-icon">👤</div>
        <div>
            <h4>Mon profil</h4>
            <p>Consultez et modifiez vos informations personnelles</p>
            <div style="margin-top: 0.75rem;">
                <a href="{{ path('profile_show') }}" class="dash-btn-outline" style="font-size:0.75rem;">👤 Voir mon profil →</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}