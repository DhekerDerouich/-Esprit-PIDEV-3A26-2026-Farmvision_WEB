{% extends 'front/base.html.twig' %}

{% block body %}
<style>
    .cp-page { padding: 2.5rem 2rem; max-width: 1200px; margin: 0 auto; }
    .cp-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2rem; }
    .cp-header h1 { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--green-deep); margin-bottom: 0.25rem; }
    .cp-header p { color: var(--text-muted); font-size: 0.95rem; }
    .cp-btn-add { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--green-mid); color: #fff; padding: 0.65rem 1.4rem; border-radius: 10px; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: background 0.2s, transform 0.15s; }
    .cp-btn-add:hover { background: var(--green-deep); transform: translateY(-1px); }
    .cp-btn-calendar { display: inline-flex; align-items: center; gap: 0.5rem; background: #f0f4f2; color: var(--green-mid); padding: 0.65rem 1.4rem; border-radius: 10px; text-decoration: none; font-weight: 600; font-size: 0.9rem; border: 1.5px solid #e0e7e3; transition: all 0.2s; }
    .cp-btn-calendar:hover { background: var(--green-mist); border-color: var(--green-mid); transform: translateY(-1px); }

    .cp-filters { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 1.25rem 1.5rem; margin-bottom: 2rem; display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
    .cp-filters label { display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-muted); margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .cp-filters input, .cp-filters select { padding: 0.55rem 0.9rem; border-radius: 8px; border: 1.5px solid #e0e7e3; background: #f8faf9; color: var(--text); font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
    .cp-filters input:focus, .cp-filters select:focus { border-color: var(--green-light); }
    .cp-filters .f-grow { flex: 1; min-width: 180px; }
    .cp-filters .f-btn { display: flex; gap: 0.5rem; align-items: flex-end; }
    .cp-btn-filter { background: var(--green-mid); color: #fff; border: none; padding: 0.55rem 1.3rem; border-radius: 8px; cursor: pointer; font-size: 0.9rem; font-weight: 600; transition: background 0.2s; }
    .cp-btn-filter:hover { background: var(--green-deep); }
    .cp-btn-reset { background: #f0f4f2; color: var(--text-muted); border: 1.5px solid #e0e7e3; padding: 0.55rem 1rem; border-radius: 8px; text-decoration: none; font-size: 0.9rem; transition: background 0.2s; }
    .cp-btn-reset:hover { background: #e4ede8; }

    .cp-result-bar { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1.25rem; }
    .cp-result-bar span { background: var(--green-mist); color: var(--green-mid); padding: 0.2rem 0.7rem; border-radius: 20px; font-weight: 600; }

    .cp-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }

    .cp-card { background: #fff; border-radius: 16px; border: 1px solid #e8f0eb; box-shadow: 0 2px 16px rgba(45,106,79,0.06); overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; display: flex; flex-direction: column; }
    .cp-card:hover { transform: translateY(-3px); box-shadow: 0 8px 32px rgba(45,106,79,0.12); }
    .cp-card-top { background: linear-gradient(135deg, #d8f3dc 0%, #b7e4c7 100%); padding: 1.5rem 1.5rem 1rem; display: flex; align-items: center; gap: 1rem; }
    .cp-card-icon { font-size: 2.2rem; line-height: 1; }
    .cp-card-title { font-size: 1.1rem; font-weight: 700; color: var(--green-deep); }
    .cp-card-type { font-size: 0.8rem; color: var(--green-mid); font-weight: 500; margin-top: 0.15rem; background: rgba(255,255,255,0.6); display: inline-block; padding: 0.15rem 0.6rem; border-radius: 20px; }
    .cp-card-body { padding: 1rem 1.5rem; flex: 1; }
    .cp-card-row { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem; }
    .cp-card-row strong { color: var(--text); }
    .cp-card-footer { padding: 1rem 1.5rem; border-top: 1px solid #f0f4f2; display: flex; gap: 0.6rem; }
    .cp-btn-edit { flex: 1; text-align: center; padding: 0.55rem; border-radius: 8px; border: 1.5px solid var(--green-mid); color: var(--green-mid); text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: background 0.2s; }
    .cp-btn-edit:hover { background: var(--green-mist); }
    .cp-btn-del { padding: 0.55rem 0.9rem; border-radius: 8px; background: #fff0f0; border: 1.5px solid #fcc; color: #e74c3c; cursor: pointer; font-size: 0.85rem; font-weight: 600; transition: background 0.2s; }
    .cp-btn-del:hover { background: #ffe0e0; }

    .cp-empty { grid-column: 1/-1; text-align: center; padding: 4rem 2rem; color: var(--text-muted); }
    .cp-empty-icon { font-size: 3rem; margin-bottom: 1rem; }

    /* Modal */
    .cp-modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 9999; justify-content: center; align-items: center; }
    .cp-modal { background: #fff; border-radius: 16px; padding: 2rem; max-width: 400px; width: 90%; box-shadow: 0 24px 64px rgba(0,0,0,0.2); text-align: center; }
    .cp-modal-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .cp-modal h3 { font-size: 1.1rem; font-weight: 700; color: #1a1a18; margin-bottom: 0.5rem; }
    .cp-modal p { font-size: 0.9rem; color: #5a6b5e; margin-bottom: 1.5rem; line-height: 1.5; }
    .cp-modal-actions { display: flex; gap: 0.75rem; }
    .cp-modal-cancel { flex: 1; padding: 0.7rem; background: #f5f5f5; border: 1.5px solid #e0e0e0; border-radius: 10px; cursor: pointer; font-size: 0.95rem; color: #333; font-weight: 500; }
    .cp-modal-confirm { flex: 1; padding: 0.7rem; background: #e74c3c; border: none; border-radius: 10px; cursor: pointer; font-size: 0.95rem; color: #fff; font-weight: 600; }
    .cp-modal-confirm:hover { background: #c0392b; }

    /* Pagination Styling */
    .pagination { display: flex; gap: 0.5rem; list-style: none; padding: 0; margin: 0; align-items: center; }
    .pagination li { display: inline-block; }
    .pagination a, .pagination span { display: inline-block; padding: 0.5rem 0.9rem; border-radius: 8px; text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: all 0.2s; }
    .pagination a { background: #f8faf9; color: var(--green-mid); border: 1.5px solid #e0e7e3; }
    .pagination a:hover { background: var(--green-mist); border-color: var(--green-mid); }
    .pagination .current { background: var(--green-mid); color: #fff; border: 1.5px solid var(--green-mid); font-weight: 600; }
    .pagination .disabled { color: #ccc; cursor: not-allowed; background: #f5f5f5; border: 1.5px solid #e0e0e0; }
</style>

<div class="cp-page">
    <div class="cp-header">
        <div>
            <h1>🌿 Mes cultures</h1>
            <p>Suivi de toutes vos cultures en cours et passées</p>
        </div>
        <div style="display: flex; gap: 0.75rem;">
            <a href="{{ path('front_culture_calendar') }}" class="cp-btn-calendar">📅 Calendrier</a>
            <a href="{{ path('front_culture_new') }}" class="cp-btn-add">+ Ajouter une culture</a>
        </div>
    </div>

    <div class="cp-filters">
        <form method="get" action="{{ path('front_culture_index') }}" style="display:contents;">
            <div class="f-grow">
                <label>Rechercher</label>
                <input type="text" name="search" value="{{ search }}" placeholder="Nom de la culture...">
            </div>
            <div>
                <label>Type</label>
                <select name="type">
                    <option value="all" {% if selectedType == 'all' %}selected{% endif %}>Tous les types</option>
                    {% for type in types %}
                        <option value="{{ type }}" {% if selectedType == type %}selected{% endif %}>{{ type }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="f-btn">
                <button type="submit" class="cp-btn-filter">Filtrer</button>
                <a href="{{ path('front_culture_index') }}" class="cp-btn-reset">Réinitialiser</a>
            </div>
        </form>
    </div>

    {% if search or selectedType != 'all' %}
    <div class="cp-result-bar">
        <span>{{ cultures.getTotalItemCount }}</span> résultat(s) trouvé(s)
        {% if search %} pour "{{ search }}"{% endif %}
        {% if selectedType != 'all' %} · Type : {{ selectedType }}{% endif %}
    </div>
    {% endif %}

    <div class="cp-grid">
        {% for culture in cultures %}
        <div class="cp-card">
            <div class="cp-card-top">
                <div class="cp-card-icon">🌱</div>
                <div>
                    <div class="cp-card-title">{{ culture.nomCulture }}</div>
                    <div class="cp-card-type">{{ culture.typeCulture }}</div>
                </div>
            </div>
            <div class="cp-card-body">
                <div class="cp-card-row">🗓 Semis : <strong>{{ culture.dateSemis ? culture.dateSemis|date('d/m/Y') : '—' }}</strong></div>
                <div class="cp-card-row">🌾 Récolte : <strong>{{ culture.dateRecolte ? culture.dateRecolte|date('d/m/Y') : 'Non définie' }}</strong></div>
            </div>
            <div class="cp-card-footer">
                <a href="{{ path('front_culture_edit', {'idCulture': culture.idCulture}) }}" class="cp-btn-edit">✏️ Modifier</a>
                <button class="cp-btn-del" onclick="openModal('{{ path('front_culture_delete', {'idCulture': culture.idCulture}) }}','{{ csrf_token('delete_culture_' ~ culture.idCulture) }}','{{ culture.nomCulture|e('js') }}')">🗑️ Supprimer</button>
            </div>
        </div>
        {% else %}
        <div class="cp-empty">
            <div class="cp-empty-icon">🌱</div>
            <p>Aucune culture trouvée.</p>
        </div>
        {% endfor %}
    </div>

    {# Pagination - always show to demonstrate KnpPaginatorBundle usage #}
    <div style="margin-top: 2rem; display: flex; justify-content: center; flex-direction: column; align-items: center; gap: 1rem;">
        <div style="font-size: 0.85rem; color: var(--text-muted);">
            Affichage de {{ cultures|length }} culture(s) sur {{ cultures.getTotalItemCount }} au total
        </div>
        <div style="background: #fff; padding: 1rem 1.5rem; border-radius: 12px; border: 1px solid #e8f0eb; box-shadow: 0 2px 8px rgba(45,106,79,0.08);">
            {{ knp_pagination_render(cultures) }}
        </div>
    </div>
</div>

<div class="cp-modal-overlay" id="deleteModal">
    <div class="cp-modal">
        <div class="cp-modal-icon">🗑️</div>
        <h3>Confirmer la suppression</h3>
        <p id="deleteModalText"></p>
        <div class="cp-modal-actions">
            <button class="cp-modal-cancel" onclick="closeModal()">Annuler</button>
            <form id="deleteForm" method="post" style="flex:1;">
                <input type="hidden" name="_token" id="deleteToken">
                <button type="submit" class="cp-modal-confirm" style="width:100%;">Supprimer</button>
            </form>
        </div>
    </div>
</div>

<script>
function openModal(action, token, name) {
    document.getElementById('deleteForm').action = action;
    document.getElementById('deleteToken').value = token;
    document.getElementById('deleteModalText').textContent = 'Voulez-vous vraiment supprimer "' + name + '" ? Cette action est irréversible.';
    document.getElementById('deleteModal').style.display = 'flex';
}
function closeModal() { document.getElementById('deleteModal').style.display = 'none'; }
document.getElementById('deleteModal').addEventListener('click', function(e) { if (e.target === this) closeModal(); });
</script>
{% endblock %}
