<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Liste des Parcelles - FarmVision</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'DejaVu Sans', Arial, sans-serif;
            font-size: 11pt;
            color: #333;
            line-height: 1.6;
        }
        
        .header {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 3px solid #4CAF50;
        }
        
        .header h1 {
            color: #2d6a4f;
            font-size: 24pt;
            margin-bottom: 5px;
        }
        
        .header .subtitle {
            color: #666;
            font-size: 12pt;
        }
        
        .info-section {
            background: #f5f5f5;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
        }
        
        .info-section p {
            margin: 5px 0;
        }
        
        .info-section strong {
            color: #2d6a4f;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        
        thead {
            background: #4CAF50;
            color: white;
        }
        
        th {
            padding: 12px 8px;
            text-align: left;
            font-weight: 600;
            font-size: 10pt;
        }
        
        td {
            padding: 10px 8px;
            border-bottom: 1px solid #ddd;
            font-size: 10pt;
        }
        
        tbody tr:nth-child(even) {
            background: #f9f9f9;
        }
        
        tbody tr:hover {
            background: #f0f0f0;
        }
        
        .footer {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 2px solid #e0e0e0;
            text-align: center;
            font-size: 9pt;
            color: #999;
        }
        
        .summary {
            background: #e8f5e9;
            padding: 15px;
            margin-bottom: 20px;
            border-left: 4px solid #4CAF50;
        }
        
        .summary h3 {
            color: #2d6a4f;
            margin-bottom: 10px;
        }
        
        .no-data {
            text-align: center;
            padding: 40px;
            color: #999;
            font-style: italic;
        }
        
        .gps-icon {
            color: #4CAF50;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>🗺️ FarmVision</h1>
        <div class="subtitle">Liste des Parcelles</div>
    </div>

    <div class="info-section">
        <p><strong>Généré le :</strong> {{ date|date('d/m/Y à H:i') }}</p>
        <p><strong>Utilisateur :</strong> {{ user.prenom }} {{ user.nom }}</p>
        {% if search %}
            <p><strong>Recherche :</strong> {{ search }}</p>
        {% endif %}
        {% if surfaceMin %}
            <p><strong>Surface min :</strong> {{ surfaceMin }} ha</p>
        {% endif %}
        {% if surfaceMax %}
            <p><strong>Surface max :</strong> {{ surfaceMax }} ha</p>
        {% endif %}
    </div>

    <div class="summary">
        <h3>Résumé</h3>
        <p><strong>Nombre total de parcelles :</strong> {{ parcelles|length }}</p>
        {% if parcelles|length > 0 %}
            {% set totalSurface = 0 %}
            {% for parcelle in parcelles %}
                {% set totalSurface = totalSurface + parcelle.surface %}
            {% endfor %}
            <p><strong>Surface totale :</strong> {{ totalSurface|number_format(2, '.', ',') }} hectares</p>
        {% endif %}
    </div>

    {% if parcelles|length > 0 %}
        <table>
            <thead>
                <tr>
                    <th style="width: 5%;">#</th>
                    <th style="width: 35%;">Localisation</th>
                    <th style="width: 15%;">Surface (ha)</th>
                    <th style="width: 20%;">Latitude</th>
                    <th style="width: 20%;">Longitude</th>
                    <th style="width: 5%;">GPS</th>
                </tr>
            </thead>
            <tbody>
                {% for parcelle in parcelles %}
                    <tr>
                        <td>{{ loop.index }}</td>
                        <td><strong>{{ parcelle.localisation }}</strong></td>
                        <td>{{ parcelle.surface|number_format(2, '.', ',') }}</td>
                        <td>
                            {% if parcelle.latitude %}
                                {{ parcelle.latitude|number_format(6, '.', ',') }}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td>
                            {% if parcelle.longitude %}
                                {{ parcelle.longitude|number_format(6, '.', ',') }}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td>
                            {% if parcelle.latitude and parcelle.longitude %}
                                <span class="gps-icon">✓</span>
                            {% else %}
                                -
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="no-data">
            Aucune parcelle trouvée
        </div>
    {% endif %}

    <div class="footer">
        <p>© {{ 'now'|date('Y') }} FarmVision - Agriculture Intelligente</p>
        <p>Document généré automatiquement</p>
    </div>
</body>
</html>
