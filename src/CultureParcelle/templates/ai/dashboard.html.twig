{% extends 'front/base.html.twig' %}

{% block body %}
<style>
    :root {
        --chat-bg: #f5f7fa;
        --sidebar-bg: #ffffff;
        --message-user-bg: #e8f5e9;
        --message-ai-bg: #ffffff;
        --primary-purple: #6366f1;
        --primary-green: #2d6a4f;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --border-color: #e2e8f0;
    }
    
    .ai-chat-container { 
        display: flex; 
        height: calc(100vh - 80px); 
        max-width: 1600px; 
        margin: 0 auto; 
        background: var(--chat-bg);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    }
    
    /* Sidebar */
    .ai-sidebar {
        width: 320px;
        background: var(--sidebar-bg);
        border-right: 1px solid var(--border-color);
        padding: 2rem 1.5rem;
        overflow-y: auto;
    }
    
    .ai-sidebar h3 {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .ai-data-section {
        margin-bottom: 2rem;
    }
    
    .ai-data-item {
        background: #f8fafc;
        padding: 0.875rem 1rem;
        border-radius: 10px;
        margin-bottom: 0.625rem;
        font-size: 0.875rem;
        border: 1px solid #f1f5f9;
        transition: all 0.2s;
    }
    
    .ai-data-item:hover {
        background: #f1f5f9;
        border-color: #e2e8f0;
    }
    
    .ai-data-item strong {
        color: var(--text-primary);
        display: block;
        margin-bottom: 0.25rem;
        font-weight: 600;
    }
    
    .ai-data-item small {
        color: var(--text-secondary);
        font-size: 0.8rem;
    }
    
    .ai-data-count {
        background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
        color: var(--primary-green);
        padding: 0.375rem 0.875rem;
        border-radius: 20px;
        font-size: 0.875rem;
        font-weight: 600;
    }
    
    /* Chat area */
    .ai-chat-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: var(--chat-bg);
    }
    
    .ai-chat-header {
        padding: 2rem 2.5rem;
        background: white;
        border-bottom: 1px solid var(--border-color);
    }
    
    .ai-chat-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    
    .ai-chat-header-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .ai-chat-header p {
        font-size: 0.95rem;
        color: var(--text-secondary);
        margin-left: 60px;
    }
    
    .ai-chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    
    .ai-message {
        display: flex;
        gap: 1rem;
        max-width: 75%;
        animation: fadeIn 0.4s ease-out;
    }
    
    .ai-message.user {
        align-self: flex-end;
        flex-direction: row-reverse;
    }
    
    .ai-message-avatar {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    
    .ai-message.assistant .ai-message-avatar {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    }
    
    .ai-message.user .ai-message-avatar {
        background: linear-gradient(135deg, #2d6a4f 0%, #40916c 100%);
    }
    
    .ai-message-content {
        background: var(--message-ai-bg);
        padding: 1.125rem 1.5rem;
        border-radius: 16px;
        line-height: 1.7;
        color: var(--text-primary);
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: 1px solid var(--border-color);
    }
    
    .ai-message.user .ai-message-content {
        background: var(--message-user-bg);
        border-color: #c8e6c9;
    }
    
    .ai-message-time {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-top: 0.5rem;
        padding: 0 0.25rem;
    }
    
    .ai-chat-input-area {
        padding: 1.5rem 2.5rem 2rem;
        background: white;
        border-top: 1px solid var(--border-color);
    }
    
    .ai-chat-input-wrapper {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
        max-width: 1000px;
        margin: 0 auto;
    }
    
    .ai-chat-input {
        flex: 1;
        padding: 1rem 1.5rem;
        border: 2px solid var(--border-color);
        border-radius: 16px;
        font-size: 0.95rem;
        resize: none;
        font-family: inherit;
        outline: none;
        transition: all 0.2s;
        min-height: 52px;
        max-height: 150px;
        background: #fafbfc;
    }
    
    .ai-chat-input:focus {
        border-color: var(--primary-purple);
        background: white;
        box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
    }
    
    .ai-chat-send {
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
        color: white;
        border: none;
        border-radius: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25);
    }
    
    .ai-chat-send:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.35);
    }
    
    .ai-chat-send:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }
    
    .ai-welcome {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-secondary);
        max-width: 900px;
        margin: 0 auto;
    }
    
    .ai-welcome-icon {
        font-size: 4rem;
        margin-bottom: 1.5rem;
        opacity: 0.9;
    }
    
    .ai-welcome h2 {
        font-size: 1.75rem;
        color: var(--text-primary);
        margin-bottom: 0.75rem;
        font-weight: 700;
    }
    
    .ai-welcome p {
        font-size: 1rem;
        line-height: 1.6;
    }
    
    .ai-suggestions {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
        margin-top: 2.5rem;
    }
    
    .ai-suggestion {
        background: white;
        border: 2px solid var(--border-color);
        padding: 1.25rem;
        border-radius: 14px;
        cursor: pointer;
        transition: all 0.2s;
        text-align: left;
    }
    
    .ai-suggestion:hover {
        border-color: var(--primary-purple);
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(99, 102, 241, 0.15);
    }
    
    .ai-suggestion-icon {
        font-size: 1.75rem;
        margin-bottom: 0.75rem;
        display: block;
    }
    
    .ai-suggestion-text {
        font-size: 0.9rem;
        color: var(--text-primary);
        font-weight: 500;
        line-height: 1.5;
    }
    
    .ai-typing {
        display: flex;
        gap: 0.5rem;
        padding: 1rem;
    }
    
    .ai-typing-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--primary-purple);
        animation: typing 1.4s infinite;
    }
    
    .ai-typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .ai-typing-dot:nth-child(3) { animation-delay: 0.4s; }
    
    @keyframes typing {
        0%, 60%, 100% { transform: translateY(0); opacity: 0.5; }
        30% { transform: translateY(-10px); opacity: 1; }
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Scrollbar styling */
    .ai-chat-messages::-webkit-scrollbar,
    .ai-sidebar::-webkit-scrollbar {
        width: 6px;
    }
    
    .ai-chat-messages::-webkit-scrollbar-track,
    .ai-sidebar::-webkit-scrollbar-track {
        background: transparent;
    }
    
    .ai-chat-messages::-webkit-scrollbar-thumb,
    .ai-sidebar::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
    }
    
    .ai-chat-messages::-webkit-scrollbar-thumb:hover,
    .ai-sidebar::-webkit-scrollbar-thumb:hover {
        background: #94a3b8;
    }
</style>

<div class="ai-chat-container">
    <!-- Sidebar with user data -->
    <div class="ai-sidebar">
        <div class="ai-data-section">
            <h3>📊 Vue d'ensemble</h3>
            <div class="ai-data-item">
                <strong>Cultures</strong>
                <span class="ai-data-count" id="culture-count">0</span>
            </div>
            <div class="ai-data-item">
                <strong>Parcelles</strong>
                <span class="ai-data-count" id="parcelle-count">0</span>
            </div>
        </div>
        
        <div class="ai-data-section">
            <h3>🌱 Mes Cultures</h3>
            <div id="cultures-list"></div>
        </div>
        
        <div class="ai-data-section">
            <h3>🗺️ Mes Parcelles</h3>
            <div id="parcelles-list"></div>
        </div>
    </div>
    
    <!-- Chat area -->
    <div class="ai-chat-main">
        <div class="ai-chat-header">
            <h1>
                <div class="ai-chat-header-icon">🤖</div>
                Assistant IA Agricole
            </h1>
            <p>Posez-moi vos questions sur l'agriculture, vos cultures et parcelles</p>
        </div>
        
        <div class="ai-chat-messages" id="chat-messages">
            <div class="ai-welcome">
                <div class="ai-welcome-icon">🌾</div>
                <h2>Bienvenue sur votre Assistant IA</h2>
                <p>Je suis là pour vous aider avec vos cultures et parcelles. Posez-moi n'importe quelle question sur l'agriculture !</p>
                
                <div class="ai-suggestions">
                    <div class="ai-suggestion" onclick="sendSuggestion('Quels sont les conseils pour mes cultures actuelles ?')">
                        <span class="ai-suggestion-icon">🌱</span>
                        <div class="ai-suggestion-text">Conseils pour mes cultures</div>
                    </div>
                    <div class="ai-suggestion" onclick="sendSuggestion('Comment optimiser mes parcelles ?')">
                        <span class="ai-suggestion-icon">🗺️</span>
                        <div class="ai-suggestion-text">Optimiser mes parcelles</div>
                    </div>
                    <div class="ai-suggestion" onclick="sendSuggestion('Quelle est la meilleure rotation des cultures ?')">
                        <span class="ai-suggestion-icon">🔄</span>
                        <div class="ai-suggestion-text">Rotation des cultures</div>
                    </div>
                    <div class="ai-suggestion" onclick="sendSuggestion('Quand dois-je récolter mes cultures ?')">
                        <span class="ai-suggestion-icon">📅</span>
                        <div class="ai-suggestion-text">Calendrier de récolte</div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="ai-chat-input-area">
            <div class="ai-chat-input-wrapper">
                <textarea 
                    id="chat-input" 
                    class="ai-chat-input" 
                    placeholder="Posez votre question sur l'agriculture..."
                    rows="1"
                    onkeydown="handleKeyPress(event)"
                ></textarea>
                <button class="ai-chat-send" onclick="sendMessage()" id="send-btn">
                    <span>Envoyer</span>
                    <span>→</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
let conversationHistory = [];

// Load user data
async function loadUserData() {
    try {
        // Load cultures
        const culturesResponse = await fetch('/ai-advice/cultures-data');
        if (culturesResponse.ok) {
            const cultures = await culturesResponse.json();
            document.getElementById('culture-count').textContent = cultures.length;
            
            const culturesList = document.getElementById('cultures-list');
            culturesList.innerHTML = cultures.slice(0, 5).map(c => `
                <div class="ai-data-item">
                    <strong>${c.nom}</strong>
                    <small>${c.type}</small>
                </div>
            `).join('');
        }
        
        // Load parcelles
        const parcellesResponse = await fetch('/ai-advice/parcelles-data');
        if (parcellesResponse.ok) {
            const parcelles = await parcellesResponse.json();
            document.getElementById('parcelle-count').textContent = parcelles.length;
            
            const parcellesList = document.getElementById('parcelles-list');
            parcellesList.innerHTML = parcelles.slice(0, 5).map(p => `
                <div class="ai-data-item">
                    <strong>${p.localisation}</strong>
                    <small>${p.surface} ha</small>
                </div>
            `).join('');
        }
    } catch (error) {
        console.error('Error loading user data:', error);
    }
}

function addMessage(content, isUser = false) {
    const messagesContainer = document.getElementById('chat-messages');
    const welcome = messagesContainer.querySelector('.ai-welcome');
    if (welcome) welcome.remove();
    
    const messageDiv = document.createElement('div');
    messageDiv.className = `ai-message ${isUser ? 'user' : 'assistant'}`;
    
    const time = new Date().toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    
    messageDiv.innerHTML = `
        <div class="ai-message-avatar">${isUser ? '👤' : '🤖'}</div>
        <div>
            <div class="ai-message-content">${content}</div>
            <div class="ai-message-time">${time}</div>
        </div>
    `;
    
    messagesContainer.appendChild(messageDiv);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

function showTyping() {
    const messagesContainer = document.getElementById('chat-messages');
    const typingDiv = document.createElement('div');
    typingDiv.className = 'ai-message assistant';
    typingDiv.id = 'typing-indicator';
    typingDiv.innerHTML = `
        <div class="ai-message-avatar">🤖</div>
        <div class="ai-message-content">
            <div class="ai-typing">
                <div class="ai-typing-dot"></div>
                <div class="ai-typing-dot"></div>
                <div class="ai-typing-dot"></div>
            </div>
        </div>
    `;
    messagesContainer.appendChild(typingDiv);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

function hideTyping() {
    const typing = document.getElementById('typing-indicator');
    if (typing) typing.remove();
}

async function sendMessage() {
    const input = document.getElementById('chat-input');
    const message = input.value.trim();
    
    if (!message) return;
    
    // Add user message
    addMessage(message, true);
    conversationHistory.push({ role: 'user', content: message });
    input.value = '';
    
    // Disable send button
    const sendBtn = document.getElementById('send-btn');
    sendBtn.disabled = true;
    
    // Show typing indicator
    showTyping();
    
    try {
        const response = await fetch('/ai-advice/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                message: message,
                history: conversationHistory
            })
        });
        
        const data = await response.json();
        
        hideTyping();
        
        if (data.success) {
            addMessage(data.response, false);
            conversationHistory.push({ role: 'assistant', content: data.response });
        } else {
            addMessage('❌ ' + data.error, false);
        }
    } catch (error) {
        hideTyping();
        addMessage('❌ Erreur de connexion', false);
    } finally {
        sendBtn.disabled = false;
        input.focus();
    }
}

function sendSuggestion(text) {
    document.getElementById('chat-input').value = text;
    sendMessage();
}

function handleKeyPress(event) {
    if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        sendMessage();
    }
}

// Auto-resize textarea
document.getElementById('chat-input').addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 150) + 'px';
});

// Load data on page load
loadUserData();
</script>
{% endblock %}
